    processor 6502
    include "vcs.h"
    include "macro.h"
    include "xmacro.h"
;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;
;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;
;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;
; Constants segment
; ---- COLORS
CONS_COLOR_BLACK  EQU $00
CONS_COLOR_LGREY  EQU #04
CONS_COLOR_GREY   EQU $E1
CONS_COLOR_WHITE  EQU $0E

CONS_COLOR_RED    EQU $46
CONS_COLOR_ORANGE EQU $38
CONS_COLOR_YELLOW EQU $1E
CONS_COLOR_GREEN  EQU $C6
CONS_COLOR_BLUE   EQU $A6
CONS_COLOR_PURPLE EQU $64

CONS_COLOR_PINK   EQU $3C
CONS_COLOR_TEAL   EQU $8D
CONS_COLOR_CHART  EQU $CA
; ---- COLOR MAPPING TO OBJECT
CONS_COLOR_OBJ_PLAYER_TILE_A EQU #CONS_COLOR_LGREY
CONS_COLOR_OBJ_PLAYER_TILE_B EQU #CONS_COLOR_WHITE


;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;
;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;
;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;
; Macros
;--------
; FLIP_BOOL
; Original author: Andy Garber
; Takes a memory address and flips it's value than stores it
; Assumes the Memory address value is 1 or 0
; usage: FLIP_BOOL SomeAddress
    MAC FLIP_BOOL
.MEMADDR     SET {1}
    lda .MEMADDR
    EOR #$01
    sta .MEMADDR
    ENDM

;--------
; LOAD_POINTER_WITH_DATA
; Original author: Andy Garber
; Loads a pointer with low byte than high byte address of data object
; usage: LOAD_POINTER_WITH_DATA pointer data
    MAC LOAD_POINTER_WITH_DATA
.POINTER      SET {1}
.DATA_BLOB    SET {2}
    lda #<.DATA_BLOB
    sta .POINTER
    lda #>.DATA_BLOB
    sta .POINTER+1
    ENDM


;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;
;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;
;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;
; Variables segment

    seg.u Variables
    org $80

TempByte .byte


CONS_BQ_VERT_COLS        EQU #5
CONS_BQ_VERT_ROWS        EQU #5
CONS_BQ_VERT_ROW_HEIGHT  EQU #10
;
CONS_BQ_HORI_COLS        EQU #5
CONS_BQ_HORI_ROWS        EQU #3
CONS_BQ_HORI_ROW_HEIGHT  EQU #8
;
CONS_PLAYERZ_COLS        EQU #5
CONS_PLAYERZ_ROWS        EQU #3
CONS_PLAYERZ_ROW_HEIGHT  EQU #8

BlockQueue_Current_Start .byte
BlockQueue_Current_Veri .DS #CONS_BQ_VERT_COLS
BlockQueue_Current_Hori .DS #CONS_BQ_HORI_COLS

BlockQueue_Top   .DS #CONS_BQ_VERT_ROWS * #CONS_BQ_VERT_COLS
BlockQueue_Bot   .DS #CONS_BQ_VERT_ROWS * #CONS_BQ_VERT_COLS
BlockQueue_Left  .DS #CONS_BQ_HORI_ROWS * #CONS_BQ_HORI_COLS
BlockQueue_Right .DS #CONS_BQ_HORI_ROWS * #CONS_BQ_HORI_COLS

Player0Pos_Col .byte
Player0Pos_Row .byte
Player0Pos_X .byte
Player0Pos_Y .byte
Player0Pos_Ptr .DS 2
Player0_Color  .byte
Player0_InputSettings .DS 2 ; 0 == current, 1 == previous

Player1Pos_Col .byte
Player1Pos_Row .byte
Player1Pos_X .byte
Player1Pos_Y .byte
Player1_Color .byte

LoopIdx .DS 2
;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;
;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;
;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;
; Code segment
    seg Code
    org $f000

Start
    CLEAN_START
;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;
; Lets build some mock data for the blocks

;;;;;;;;;;;;;;;;;;;;;;;
    lda #$00
    sta TempByte

    lda #CONS_BQ_VERT_ROWS
    sta LoopIdx

    ldx #$00

Kernal_Temp_Rows
    ldy #CONS_BQ_VERT_COLS

Kernal_Temp_Cols
    FLIP_BOOL TempByte
    bne Kernal_Temp_B

Kernal_Temp_A
    lda #CONS_COLOR_ORANGE
    sta BlockQueue_Top,x
    jmp Kernal_Temp_Next

Kernal_Temp_B
    lda #CONS_COLOR_RED
    sta BlockQueue_Top,x

Kernal_Temp_Next
    inx
    dey
    bne Kernal_Temp_Cols

    lda #CONS_COLOR_BLACK
    dec LoopIdx
    bne Kernal_Temp_Rows

    lda #$FF
    sta BlockQueue_Top,x
;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;
; Setup Other Player Things
    lda #CONS_COLOR_RED
    sta Player0_Color
    lda #00
    sta Player0Pos_Row
    lda #$04
    sta Player0Pos_Col
    ; Set level data
    LOAD_POINTER_WITH_DATA Player0Pos_Ptr,PlayerXCoordinates
;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;
;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;
;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;
; On Frame Code segment

NextFrame
    lsr SWCHB    ; test Game Reset switch
    bcc Start    ; reset?

; 1 + 3 lines of VSYNC
    VERTICAL_SYNC

;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;
; 37 lines of underscan

    TIMER_SETUP 37
    
;;;;;;;;;;;;;;;;;;;;;;;
; Set Positions
    ldy Player0Pos_Col
    lda (Player0Pos_Ptr),y ;Player0Pos_X ; get X coordinate
    sta WSYNC
    ldx #0           ; player 0
    jsr SetHorizPos  ; set coarse offset    
    TIMER_WAIT

;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;
; 192 lines of frame

    TIMER_SETUP 192
;;;;;;;;;;;;;;;;;;;;;;;
    lda #%00000001
    sta CTRLPF
    lda #CONS_COLOR_BLACK
    sta COLUPF
    
    lda #%11110000
    sta PF0
    lda #%11111110
    sta PF1
    lda #%00000000
    sta PF2
;;;;;;;;;;;;;;;;;;;;;;;    
    lda Player0_Color
    sta COLUP0
;;;;;;;;;;;;;;;;;;;;;;;
    lda #%00000001
    sta CTRLPF
    lda #CONS_COLOR_BLACK
    sta COLUPF
    
    lda #%11110000
    sta PF0
    lda #%11111110
    sta PF1
    lda #%00000000
    sta PF2
    
    lda #CONS_BQ_VERT_ROWS
    sta LoopIdx
    lda #$00
    sta BlockQueue_Current_Start
    sta WSYNC
Kernal_TopBlocks
    jsr SetupCurrentRow
    ldy #CONS_BQ_VERT_ROW_HEIGHT
Kernal_TopBlocks.Rows
    sta WSYNC

    ;lda BlockQueue_Current_Veri,0
    lda #CONS_COLOR_PURPLE
    sta COLUBK

    SLEEP 32

    ;lda BlockQueue_Current_Veri,1
    lda #CONS_COLOR_GREEN
    sta COLUBK

    ;lda BlockQueue_Current_Veri,2
    lda #CONS_COLOR_PURPLE
    sta COLUBK

    ;lda BlockQueue_Current_Veri,3
    lda #CONS_COLOR_GREEN
    sta COLUBK

    ;lda BlockQueue_Current_Veri,4
    lda #CONS_COLOR_PURPLE
    sta COLUBK
    
    dey
    bne Kernal_TopBlocks.Rows

    lda #CONS_COLOR_BLACK
    sta COLUBK
    sta WSYNC

    dec LoopIdx
    bne Kernal_TopBlocks

;;;;;;;;;;;;;;;;;;;;;;;
    lda #%00000001
    sta CTRLPF
    lda #CONS_COLOR_BLACK
    sta COLUPF
    ; TODO --- may use seperate playfields but not positive!
    lda #%11110000
    sta PF0
    lda #%11111110
    sta PF1
    lda #%00000000
    sta PF2

    lda #CONS_PLAYERZ_ROWS
    sta LoopIdx
    ldx #00
Kernal_PlayerZone
    ;Player is on for FULL size of block so lets do that based on X
    cpx Player0Pos_Row
    bne Kernal_PlayerZone.Off
Kernal_PlayerZone.On
    lda #%00001111
    jmp Kernal_PlayerZone.StoreGRP0
Kernal_PlayerZone.Off
    lda #00
Kernal_PlayerZone.StoreGRP0
    sta GRP0
    ldy #CONS_PLAYERZ_ROW_HEIGHT
Kernal_PlayerZone.Rows
    sta WSYNC
    ;Load Player Graphic based on side
    SLEEP 32
    ;Draw Tiles
    lda #CONS_COLOR_OBJ_PLAYER_TILE_A
    sta COLUBK
    REPEAT 2
        lda #CONS_COLOR_OBJ_PLAYER_TILE_B
        sta COLUBK
        lda #CONS_COLOR_OBJ_PLAYER_TILE_A
        sta COLUBK
    REPEND

    dey
    bne Kernal_PlayerZone.Rows
    ;Turn off graphics for a line didider
    lda #CONS_COLOR_BLACK
    sta COLUBK
    sta GRP0
    inx
    sta WSYNC

    dec LoopIdx
    bne Kernal_PlayerZone

;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;
Kernal_WaitTilEnd
    lda #00
    sta GRP0
    
    lda #CONS_COLOR_BLACK
    sta COLUPF

    lda #%00000000
    sta PF0

    lda #%00000000
    sta PF1

    lda #%00000000
    sta PF2

    jsr ReadJoystick
    
    nop
    TIMER_WAIT

;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;
; 29 lines of overscan

    TIMER_SETUP 29
    TIMER_WAIT

; total = 262 lines, go to next frame
    jmp NextFrame

;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;
;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;
;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;
; Subroutines


;;;;;;;;;;;;;;;;;;;;;;;
; No parameters
; Takes 2 Lines
SetupCurrentRow
; for the first we determine if we need to set the 2 bytes in PF1
    ldx #CONS_PLAYERZ_COLS
    lda BlockQueue_Current_Start
    adc #CONS_PLAYERZ_COLS-1
    sta BlockQueue_Current_Start
    tay
SetupCurrentRow.1
    lda BlockQueue_Top,y
    sta BlockQueue_Current_Veri,x
    dey
    dex
    bne SetupCurrentRow.1
    rts
;;;;;;;;;;;;;;;;;;;;;;;    
; A = X coordinate
; X = player number (0 or 1)
SetHorizPos
        sta WSYNC	; start a new line
        sec		; set carry flag
SetHorizPos.1
	sbc #15		; subtract 15
	bcs SetHorizPos.1 ; branch until negative
	eor #7		; calculate fine offset
        asl
        asl
        asl
        asl
        sta RESP0,x	; fix coarse position
        sta HMP0,x	; set fine offset
        sta WSYNC
        sta HMOVE	; apply the previous fine position(s)
	sta HMCLR	; reset the old horizontal position(s)
        rts		; return to caller
;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;
;-----------------------------------------
; SWCHA -- directional register
; #%10000000 -- P1 Right
; #%01000000 -- P1 left
; #%00100000 -- P1 down
; #%00010000 -- P1 up
; #%00001000 -- P0 Right
; #%00000100 -- P0 left
; #%00000010 -- P0 down
; #%00000001 -- P0 up
ReadJoystick
      lda #%00000000
      sta Player0_InputSettings  ; Set current input state to 0
.ReadJoystick
; ----------------------
; LEFT
; ----------------------
      lda #%01000000
      bit SWCHA
      bne .checkRight

      lda Player0_InputSettings
      ora #%00000001
      sta Player0_InputSettings

; ----------------------
; RIGHT
; ----------------------
.checkRight
      lda #%10000000
      bit SWCHA
      bne .checkUp

      lda Player0_InputSettings
      ora #%00000010
      sta Player0_InputSettings

; ----------------------
; UP
; ----------------------
.checkUp
      lda #%00010000
      bit SWCHA
      bne .checkDown

      lda Player0_InputSettings
      ora #%00001000
      sta Player0_InputSettings

; ----------------------
; DOWN
; ----------------------
.checkDown
      lda #%00100000
      bit SWCHA
      bne .checkbutton

      lda Player0_InputSettings
      ora #%00010000
      sta Player0_InputSettings
      
.checkbutton
      bit INPT4
      bmi .determineJoystickAction ; released
      lda Player0_InputSettings
      ora #%00000100
      sta Player0_InputSettings
      
.determineJoystickAction
        lda Player0_InputSettings
        bne .storeCurrentInput
        lda Player0_InputSettings+1
        beq .storeCurrentInput

        tax
        ; Fire on release
        and #%00000100
        bne .fireOnRelease

; LEFT RELEASE
      txa
      and #%00000001
      bne .leftOnRelease

; RIGHT RELEASE
      txa
      and #%00000010
      bne .rightOnRelease

; UP RELEASE
      txa
      and #%00001000
      bne .upOnRelease

; DOWN RELEASE
      txa
      and #%00010000
      bne .downOnRelease
.leftOnRelease
	lda Player0Pos_Col
        cmp #$00
        beq .storeCurrentInput
	dec Player0Pos_Col
        jmp .storeCurrentInput
.rightOnRelease
	lda Player0Pos_Col
        cmp #CONS_PLAYERZ_COLS-1
        beq .storeCurrentInput
	inc Player0Pos_Col
        jmp .storeCurrentInput
.upOnRelease
	lda Player0Pos_Row
        cmp #$00
        beq .storeCurrentInput
	dec Player0Pos_Row
        jmp .storeCurrentInput
.downOnRelease
	lda Player0Pos_Row
        cmp #CONS_PLAYERZ_ROWS-1
        beq .storeCurrentInput
	inc Player0Pos_Row
        jmp .storeCurrentInput
.fireOnRelease
.storeCurrentInput
        lda Player0_InputSettings
        sta Player0_InputSettings+1
.endJoystickCheck
      rts

;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;
;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;
;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;
; Data
;;;;;;;;;;;;;;;;;;;;;;;
PlayerXCoordinates
    .byte #$34
    .byte #$43
    .byte #$52
    .byte #$61
    .byte #$70
;;;;;;;;;;;;;;;;;;;;;;;
PlayerSprite_Up
    .byte #%11111111
    .byte #%11111111
    .byte #%11111111
    .byte #%11111111
    .byte #%11111111
    .byte #%11111111
    .byte #%11111111
    .byte #%11111111
;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;
;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;
;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;
; Epilogue

    org $fffc
    .word Start    ; reset vector
    .word Start    ; BRK vector