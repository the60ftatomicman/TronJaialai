    695  f30b
    696  f30b				   .checkbutton
    697  f30b		       a9 80		      lda	#%10000000	; Load the state of the P1 button into the accumulator (A)
    698  f30d		       24 0c		      bit	INPT4	; Test bit 7 of the accumulator.
    699  f30f		       90 06		      bcc	.determineJoystickAction	; If BIT 7 is 1 (Negative), button is released
