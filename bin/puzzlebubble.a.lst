    699  f354							;-----------------------------------------
    700  f354							; SWCHA -- directional register
    701  f354							; #%10000000 -- P1 Right
    702  f354							; #%01000000 -- P1 left
    703  f354							; #%00100000 -- P1 down
    704  f354							; #%00010000 -- P1 up
    705  f354							; #%00001000 -- P0 Right
    706  f354							; #%00000100 -- P0 left
    707  f354							; #%00000010 -- P0 down
    708  f354							; #%00000001 -- P0 up
    709  f354				   ReadJoystick
    710  f354		       a9 00		      lda	#%00000000
    711  f356		       85 f2		      sta	PlayerInputSettings	; Set current input state to 0
    712  f358
    713  f358				   .checkLeft
    714  f358		       a9 40		      lda	#%01000000
    715  f35a		       2c 80 02 	      bit	SWCHA	; Read Joystick directions`
    716  f35d		       d0 06		      bne	.checkRight	; If 0, Left is pressed
    717  f35f
    718  f35f		       a5 f2		      lda	PlayerInputSettings
    719  f361		       09 01		      ora	#%00000001	; Left bit
    720  f363		       85 f2		      sta	PlayerInputSettings
    721  f365				   .checkRight
    722  f365		       a9 80		      lda	#%10000000
    723  f367		       2c 80 02 	      bit	SWCHA	; Mask for Bit 7
    724  f36a		       d0 06		      bne	.checkbutton	; If 0, Right is pressed
    725  f36c
    726  f36c		       a5 f2		      lda	PlayerInputSettings
    727  f36e		       09 02		      ora	#%00000010	; Right bit
    728  f370		       85 f2		      sta	PlayerInputSettings
    729  f372
    730  f372				   .checkbutton
    731  f372		       24 0c		      bit	INPT4
    732  f374		       30 06		      bmi	.determineJoystickAction	; released
    733  f376		       a5 f2		      lda	PlayerInputSettings
    734  f378		       09 04		      ora	#%00000100
    735  f37a		       85 f2		      sta	PlayerInputSettings
    736  f37c
    737  f37c				   .determineJoystickAction
    738  f37c		       a5 f2		      lda	PlayerInputSettings
    739  f37e		       d0 38		      bne	.storeCurrentInput
    740  f380		       a5 f3		      lda	PlayerInputSettings+1
    741  f382		       f0 34		      beq	.storeCurrentInput
    742  f384
    743  f384		       aa		      tax
    744  f385							; Fire on release
    745  f385		       29 04		      and	#%00000100
    746  f387		       d0 2b		      bne	.fireOnRelease
    747  f389
    748  f389		       8a		      txa
    749  f38a		       29 01		      and	#%00000001
    750  f38c		       d0 08		      bne	.leftOnRelease
    751  f38e
    752  f38e		       8a		      txa
    753  f38f		       29 02		      and	#%00000010
    754  f391		       d0 11		      bne	.rightOnRelease
    755  f393		       4c b8 f3 	      jmp	.storeCurrentInput
    756  f396
    757  f396				   .leftOnRelease
    758  f396		       38		      sec
    759  f397		       a5 f1		      lda	PlayerLauncherIdx
    760  f399		       e9 01		      sbc	#CONS_LAUNCHER_IDX_STEP
    761  f39b		       10 02		      bpl	.storeLeftIdx
    762  f39d		       a9 00		      lda	#$00
    763  f39f				   .storeLeftIdx
    764  f39f		       85 f1		      sta	PlayerLauncherIdx
    765  f3a1		       4c b8 f3 	      jmp	.storeCurrentInput
    766  f3a4
    767  f3a4				   .rightOnRelease
    768  f3a4		       18		      clc
    769  f3a5		       a5 f1		      lda	PlayerLauncherIdx
    770  f3a7		       69 01		      adc	#CONS_LAUNCHER_IDX_STEP
    771  f3a9		       c9 06		      cmp	#$06
    772  f3ab		       90 02		      bcc	.storeRightIdx
    773  f3ad		       a9 06		      lda	#$06
    774  f3af				   .storeRightIdx
    775  f3af		       85 f1		      sta	PlayerLauncherIdx
    776  f3b1		       4c b8 f3 	      jmp	.storeCurrentInput
    777  f3b4
    778  f3b4				   .fireOnRelease
