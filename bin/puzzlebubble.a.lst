    644  f303							;-----------------------------------------
    645  f303							; SWCHA -- directional register
    646  f303							; #%10000000 -- P1 Right
    647  f303							; #%01000000 -- P1 left
    648  f303							; #%00100000 -- P1 down
    649  f303							; #%00010000 -- P1 up
    650  f303							; #%00001000 -- P0 Right
    651  f303							; #%00000100 -- P0 left
    652  f303							; #%00000010 -- P0 down
    653  f303							; #%00000001 -- P0 up
    654  f303				   ReadJoystick
    655  f303		       a9 00		      lda	#%00000000
    656  f305		       85 f2		      sta	PlayerInputSettings	; Set current input state to 0
    657  f307
    658  f307				   .checkLeft
    659  f307		       a9 40		      lda	#%01000000
    660  f309		       2c 80 02 	      bit	SWCHA	; Read Joystick directions`
    661  f30c		       d0 06		      bne	.checkRight	; If 0, Left is pressed
    662  f30e
    663  f30e		       a5 f2		      lda	PlayerInputSettings
    664  f310		       09 01		      ora	#%00000001	; Left bit
    665  f312		       85 f2		      sta	PlayerInputSettings
    666  f314				   .checkRight
    667  f314		       a9 80		      lda	#%10000000
    668  f316		       2c 80 02 	      bit	SWCHA	; Mask for Bit 7
    669  f319		       d0 06		      bne	.checkbutton	; If 0, Right is pressed
    670  f31b
    671  f31b		       a5 f2		      lda	PlayerInputSettings
    672  f31d		       09 02		      ora	#%00000010	; Right bit
    673  f31f		       85 f2		      sta	PlayerInputSettings
    674  f321
    675  f321				   .checkbutton
    676  f321		       24 0c		      bit	INPT4
    677  f323		       30 06		      bmi	.determineJoystickAction	; released
    678  f325		       a5 f2		      lda	PlayerInputSettings
    679  f327		       09 04		      ora	#%00000100
    680  f329		       85 f2		      sta	PlayerInputSettings
    681  f32b
    682  f32b				   .determineJoystickAction
    683  f32b		       a5 f2		      lda	PlayerInputSettings
    684  f32d		       d0 38		      bne	.storeCurrentInput
    685  f32f		       a5 f3		      lda	PlayerInputSettings+1
    686  f331		       f0 34		      beq	.storeCurrentInput
    687  f333
    688  f333		       aa		      tax
    689  f334							; Fire on release
    690  f334		       29 04		      and	#%00000100
    691  f336		       d0 2b		      bne	.fireOnRelease
    692  f338
    693  f338		       8a		      txa
    694  f339		       29 01		      and	#%00000001
    695  f33b		       d0 08		      bne	.leftOnRelease
    696  f33d
    697  f33d		       8a		      txa
    698  f33e		       29 02		      and	#%00000010
    699  f340		       d0 11		      bne	.rightOnRelease
    700  f342		       4c 67 f3 	      jmp	.storeCurrentInput
    701  f345
    702  f345				   .leftOnRelease
    703  f345		       38		      sec
    704  f346		       a5 f1		      lda	PlayerLauncherIdx
    705  f348		       e9 01		      sbc	#CONS_LAUNCHER_IDX_STEP
    706  f34a		       10 02		      bpl	.storeLeftIdx
    707  f34c		       a9 00		      lda	#$00
    708  f34e				   .storeLeftIdx
    709  f34e		       85 f1		      sta	PlayerLauncherIdx
    710  f350		       4c 67 f3 	      jmp	.storeCurrentInput
    711  f353
    712  f353				   .rightOnRelease
    713  f353		       18		      clc
    714  f354		       a5 f1		      lda	PlayerLauncherIdx
    715  f356		       69 01		      adc	#CONS_LAUNCHER_IDX_STEP
    716  f358		       c9 06		      cmp	#$06
    717  f35a		       90 02		      bcc	.storeRightIdx
    718  f35c		       a9 06		      lda	#$06
    719  f35e				   .storeRightIdx
    720  f35e		       85 f1		      sta	PlayerLauncherIdx
    721  f360		       4c 67 f3 	      jmp	.storeCurrentInput
    722  f363
    723  f363				   .fireOnRelease
    724  f363		       a9 01		      lda	#CONS_PLAYER_STATE_MOVING
    725  f365		       85 f0		      sta	PlayerState
    726  f367				   .storeCurrentInput
    727  f367		       a5 f2		      lda	PlayerInputSettings
    728  f369		       85 f3		      sta	PlayerInputSettings+1
    729  f36b				   .endJoystickCheck
    730  f36b		       60		      rts
