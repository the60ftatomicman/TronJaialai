    646  f2d0		       2c 80 02 	      bit	SWCHA	; Read Joystick directions`
    647  f2d3		       d0 06		      bne	.checkRight	; If 0, Left is pressed
    648  f2d5
    649  f2d5		       a5 f2		      lda	PlayerInputSettings
    650  f2d7		       09 01		      ora	#%00000001	; Left bit
    651  f2d9		       85 f2		      sta	PlayerInputSettings
    652  f2db				   .checkRight
    653  f2db		       a9 80		      lda	#%10000000
    654  f2dd		       2c 80 02 	      bit	SWCHA	; Mask for Bit 7
    655  f2e0		       d0 06		      bne	.checkbutton	; If 0, Right is pressed
    656  f2e2
    657  f2e2		       a5 f2		      lda	PlayerInputSettings
    658  f2e4		       09 02		      ora	#%00000010	; Right bit
    659  f2e6		       85 f2		      sta	PlayerInputSettings
    660  f2e8
    661  f2e8				   .checkbutton
    662  f2e8		       24 0c		      bit	INPT4
    663  f2ea		       30 06		      bmi	.determineJoystickAction	; released
    664  f2ec		       a5 f2		      lda	PlayerInputSettings
    665  f2ee		       09 04		      ora	#%00000100
    666  f2f0		       85 f2		      sta	PlayerInputSettings
