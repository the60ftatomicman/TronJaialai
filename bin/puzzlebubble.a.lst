    715  f36a							; SWCHA -- directional register
    716  f36a							; #%10000000 -- P1 Right
    717  f36a							; #%01000000 -- P1 left
    718  f36a							; #%00100000 -- P1 down
    719  f36a							; #%00010000 -- P1 up
    720  f36a							; #%00001000 -- P0 Right
    721  f36a							; #%00000100 -- P0 left
    722  f36a							; #%00000010 -- P0 down
    723  f36a							; #%00000001 -- P0 up
    724  f36a				   ReadJoystick
    725  f36a		       a9 00		      lda	#%00000000
    726  f36c		       85 f2		      sta	PlayerInputSettings	; Set current input state to 0
    727  f36e
    728  f36e				   .checkLeft
    729  f36e		       a9 40		      lda	#%01000000
    730  f370		       2c 80 02 	      bit	SWCHA	; Read Joystick directions`
    731  f373		       d0 06		      bne	.checkRight	; If 0, Left is pressed
    732  f375
    733  f375		       a5 f2		      lda	PlayerInputSettings
    734  f377		       09 01		      ora	#%00000001	; Left bit
    735  f379		       85 f2		      sta	PlayerInputSettings
    736  f37b				   .checkRight
    737  f37b		       a9 80		      lda	#%10000000
    738  f37d		       2c 80 02 	      bit	SWCHA	; Mask for Bit 7
    739  f380		       d0 06		      bne	.checkbutton	; If 0, Right is pressed
    740  f382
    741  f382		       a5 f2		      lda	PlayerInputSettings
    742  f384		       09 02		      ora	#%00000010	; Right bit
    743  f386		       85 f2		      sta	PlayerInputSettings
    744  f388
    745  f388				   .checkbutton
    746  f388		       24 0c		      bit	INPT4
    747  f38a		       30 06		      bmi	.determineJoystickAction	; released
    748  f38c		       a5 f2		      lda	PlayerInputSettings
    749  f38e		       09 04		      ora	#%00000100
    750  f390		       85 f2		      sta	PlayerInputSettings
    751  f392
    752  f392				   .determineJoystickAction
    753  f392		       a5 f2		      lda	PlayerInputSettings
    754  f394		       d0 38		      bne	.storeCurrentInput
    755  f396		       a5 f3		      lda	PlayerInputSettings+1
    756  f398		       f0 34		      beq	.storeCurrentInput
    757  f39a
    758  f39a		       aa		      tax
    759  f39b							; Fire on release
    760  f39b		       29 04		      and	#%00000100
    761  f39d		       d0 2b		      bne	.fireOnRelease
    762  f39f
    763  f39f		       8a		      txa
    764  f3a0		       29 01		      and	#%00000001
    765  f3a2		       d0 08		      bne	.leftOnRelease
    766  f3a4
    767  f3a4		       8a		      txa
    768  f3a5		       29 02		      and	#%00000010
    769  f3a7		       d0 11		      bne	.rightOnRelease
    770  f3a9		       4c ce f3 	      jmp	.storeCurrentInput
    771  f3ac
    772  f3ac				   .leftOnRelease
    773  f3ac		       38		      sec
    774  f3ad		       a5 f1		      lda	PlayerLauncherIdx
    775  f3af		       e9 01		      sbc	#CONS_LAUNCHER_IDX_STEP
    776  f3b1		       10 02		      bpl	.storeLeftIdx
