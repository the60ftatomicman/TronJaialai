     35  0000 ????						;--------
     36  0000 ????						; FLIP_BOOL
     37  0000 ????						; Original author: Andy Garber
     38  0000 ????						; Takes a memory address and flips it's value than stores it
     39  0000 ????						; Assumes the Memory address value is 1 or 0
     40  0000 ????						; usage: FLIP_BOOL SomeAddress
     41  0000 ????				      MAC	flip_bool
     42  0000 ????			   .MEMADDR   SET	{1}
     43  0000 ????				      lda	.MEMADDR
     44  0000 ????				      EOR	#$01
     45  0000 ????				      sta	.MEMADDR
     46  0000 ????				      ENDM
     47  0000 ????						;--------
     48  0000 ????						; LOAD_POINTER_WITH_DATA
     49  0000 ????						; Original author: Andy Garber
     50  0000 ????						; Loads a pointer with low byte than high byte address of data object
     51  0000 ????						; usage: LOAD_POINTER_WITH_DATA pointer data
     52  0000 ????				      MAC	load_pointer_with_data
     53  0000 ????			   .POINTER   SET	{1}
     54  0000 ????			   .DATA_BLOB SET	{2}
     55  0000 ????				      lda	#<.DATA_BLOB
     56  0000 ????				      sta	.POINTER
     57  0000 ????				      lda	#>.DATA_BLOB
     58  0000 ????				      sta	.POINTER+1
     59  0000 ????				      ENDM
