    669  f2f2		       a5 f2		      lda	PlayerInputSettings
    670  f2f4		       d0 38		      bne	.storeCurrentInput
    671  f2f6		       a5 f3		      lda	PlayerInputSettings+1
    672  f2f8		       f0 34		      beq	.storeCurrentInput
    673  f2fa
    674  f2fa		       aa		      tax
    675  f2fb							; Fire on release
    676  f2fb		       29 04		      and	#%00000100
    677  f2fd		       d0 2b		      bne	.fireOnRelease
    678  f2ff
    679  f2ff		       8a		      txa
    680  f300		       29 01		      and	#%00000001
    681  f302		       d0 08		      bne	.leftOnRelease
    682  f304
    683  f304		       8a		      txa
    684  f305		       29 02		      and	#%00000010
    685  f307		       d0 11		      bne	.rightOnRelease
    686  f309		       4c 2e f3 	      jmp	.storeCurrentInput
    687  f30c
    688  f30c				   .leftOnRelease
    689  f30c		       38		      sec
    690  f30d		       a5 f1		      lda	PlayerLauncherIdx
    691  f30f		       e9 01		      sbc	#CONS_LAUNCHER_IDX_STEP
    692  f311		       10 02		      bpl	.storeLeftIdx
    693  f313		       a9 00		      lda	#$00
    694  f315				   .storeLeftIdx
    695  f315		       85 f1		      sta	PlayerLauncherIdx
    696  f317		       4c 2e f3 	      jmp	.storeCurrentInput
    697  f31a
    698  f31a				   .rightOnRelease
    699  f31a		       18		      clc
    700  f31b		       a5 f1		      lda	PlayerLauncherIdx
    701  f31d		       69 01		      adc	#CONS_LAUNCHER_IDX_STEP
    702  f31f		       c9 06		      cmp	#$06
    703  f321		       90 02		      bcc	.storeRightIdx
    704  f323		       a9 06		      lda	#$06
    705  f325				   .storeRightIdx
    706  f325		       85 f1		      sta	PlayerLauncherIdx
    707  f327		       4c 2e f3 	      jmp	.storeCurrentInput
    708  f32a
    709  f32a				   .fireOnRelease
    710  f32a		       a9 01		      lda	#CONS_PLAYER_STATE_MOVING
    711  f32c		       85 f0		      sta	PlayerState
    712  f32e				   .storeCurrentInput
    713  f32e		       a5 f2		      lda	PlayerInputSettings
    714  f330		       85 f3		      sta	PlayerInputSettings+1
    715  f332				   .endJoystickCheck
    716  f332		       60		      rts
