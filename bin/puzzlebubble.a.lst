    664  f326							; SWCHA -- directional register
    665  f326							; #%10000000 -- P1 Right
    666  f326							; #%01000000 -- P1 left
    667  f326							; #%00100000 -- P1 down
    668  f326							; #%00010000 -- P1 up
    669  f326							; #%00001000 -- P0 Right
    670  f326							; #%00000100 -- P0 left
    671  f326							; #%00000010 -- P0 down
    672  f326							; #%00000001 -- P0 up
    673  f326				   ReadJoystick
    674  f326		       a9 00		      lda	#%00000000
    675  f328		       85 f2		      sta	PlayerInputSettings	; Set current input state to 0
    676  f32a
    677  f32a				   .checkLeft
    678  f32a		       a9 40		      lda	#%01000000
    679  f32c		       2c 80 02 	      bit	SWCHA	; Read Joystick directions`
    680  f32f		       d0 06		      bne	.checkRight	; If 0, Left is pressed
    681  f331
    682  f331		       a5 f2		      lda	PlayerInputSettings
    683  f333		       09 01		      ora	#%00000001	; Left bit
    684  f335		       85 f2		      sta	PlayerInputSettings
    685  f337				   .checkRight
    686  f337		       a9 80		      lda	#%10000000
    687  f339		       2c 80 02 	      bit	SWCHA	; Mask for Bit 7
    688  f33c		       d0 06		      bne	.checkbutton	; If 0, Right is pressed
    689  f33e
    690  f33e		       a5 f2		      lda	PlayerInputSettings
    691  f340		       09 02		      ora	#%00000010	; Right bit
    692  f342		       85 f2		      sta	PlayerInputSettings
    693  f344
    694  f344				   .checkbutton
    695  f344		       24 0c		      bit	INPT4
    696  f346		       30 06		      bmi	.determineJoystickAction	; released
    697  f348		       a5 f2		      lda	PlayerInputSettings
    698  f34a		       09 04		      ora	#%00000100
    699  f34c		       85 f2		      sta	PlayerInputSettings
    700  f34e
    701  f34e				   .determineJoystickAction
    702  f34e		       a5 f2		      lda	PlayerInputSettings
    703  f350		       d0 38		      bne	.storeCurrentInput
    704  f352		       a5 f3		      lda	PlayerInputSettings+1
    705  f354		       f0 34		      beq	.storeCurrentInput
    706  f356
    707  f356		       aa		      tax
    708  f357							; Fire on release
    709  f357		       29 04		      and	#%00000100
    710  f359		       d0 2b		      bne	.fireOnRelease
    711  f35b
    712  f35b		       8a		      txa
    713  f35c		       29 01		      and	#%00000001
    714  f35e		       d0 08		      bne	.leftOnRelease
    715  f360
    716  f360		       8a		      txa
    717  f361		       29 02		      and	#%00000010
    718  f363		       d0 11		      bne	.rightOnRelease
    719  f365		       4c 8a f3 	      jmp	.storeCurrentInput
    720  f368
    721  f368				   .leftOnRelease
    722  f368		       38		      sec
    723  f369		       a5 f1		      lda	PlayerLauncherIdx
    724  f36b		       e9 01		      sbc	#CONS_LAUNCHER_IDX_STEP
    725  f36d		       10 02		      bpl	.storeLeftIdx
    726  f36f		       a9 00		      lda	#$00
    727  f371				   .storeLeftIdx
    728  f371		       85 f1		      sta	PlayerLauncherIdx
    729  f373		       4c 8a f3 	      jmp	.storeCurrentInput
    730  f376
    731  f376				   .rightOnRelease
    732  f376		       18		      clc
    733  f377		       a5 f1		      lda	PlayerLauncherIdx
    734  f379		       69 01		      adc	#CONS_LAUNCHER_IDX_STEP
    735  f37b		       c9 06		      cmp	#$06
    736  f37d		       90 02		      bcc	.storeRightIdx
    737  f37f		       a9 06		      lda	#$06
    738  f381				   .storeRightIdx
    739  f381		       85 f1		      sta	PlayerLauncherIdx
    740  f383		       4c 8a f3 	      jmp	.storeCurrentInput
