    694  f328
    695  f328							;-----------------------------------------
    696  f328							; SWCHA -- directional register
    697  f328							; #%10000000 -- P1 Right
    698  f328							; #%01000000 -- P1 left
    699  f328							; #%00100000 -- P1 down
    700  f328							; #%00010000 -- P1 up
    701  f328							; #%00001000 -- P0 Right
    702  f328							; #%00000100 -- P0 left
    703  f328							; #%00000010 -- P0 down
    704  f328							; #%00000001 -- P0 up
    705  f328				   ReadJoystick
    706  f328		       a9 00		      lda	#%00000000
    707  f32a		       85 f2		      sta	PlayerInputSettings	; Set current input state to 0
    708  f32c
    709  f32c				   .checkLeft
    710  f32c		       a9 40		      lda	#%01000000
    711  f32e		       2c 80 02 	      bit	SWCHA	; Read Joystick directions`
    712  f331		       d0 06		      bne	.checkRight	; If 0, Left is pressed
    713  f333
    714  f333		       a5 f2		      lda	PlayerInputSettings
    715  f335		       09 01		      ora	#%00000001	; Left bit
    716  f337		       85 f2		      sta	PlayerInputSettings
    717  f339				   .checkRight
    718  f339		       a9 80		      lda	#%10000000
    719  f33b		       2c 80 02 	      bit	SWCHA	; Mask for Bit 7
    720  f33e		       d0 06		      bne	.checkbutton	; If 0, Right is pressed
    721  f340
    722  f340		       a5 f2		      lda	PlayerInputSettings
    723  f342		       09 02		      ora	#%00000010	; Right bit
    724  f344		       85 f2		      sta	PlayerInputSettings
    725  f346
    726  f346				   .checkbutton
    727  f346		       24 0c		      bit	INPT4
    728  f348		       30 06		      bmi	.determineJoystickAction	; released
    729  f34a		       a5 f2		      lda	PlayerInputSettings
    730  f34c		       09 04		      ora	#%00000100
    731  f34e		       85 f2		      sta	PlayerInputSettings
    732  f350
    733  f350				   .determineJoystickAction
    734  f350		       a5 f2		      lda	PlayerInputSettings
    735  f352		       d0 38		      bne	.storeCurrentInput
    736  f354		       a5 f3		      lda	PlayerInputSettings+1
    737  f356		       f0 34		      beq	.storeCurrentInput
    738  f358
    739  f358		       aa		      tax
    740  f359							; Fire on release
    741  f359		       29 04		      and	#%00000100
    742  f35b		       d0 2b		      bne	.fireOnRelease
    743  f35d
    744  f35d		       8a		      txa
    745  f35e		       29 01		      and	#%00000001
    746  f360		       d0 08		      bne	.leftOnRelease
    747  f362
    748  f362		       8a		      txa
    749  f363		       29 02		      and	#%00000010
    750  f365		       d0 11		      bne	.rightOnRelease
    751  f367		       4c 8c f3 	      jmp	.storeCurrentInput
    752  f36a
    753  f36a				   .leftOnRelease
    754  f36a		       38		      sec
    755  f36b		       a5 f1		      lda	PlayerLauncherIdx
    756  f36d		       e9 03		      sbc	#CONS_LAUNCHER_IDX_STEP
    757  f36f		       10 02		      bpl	.storeLeftIdx
    758  f371		       a9 00		      lda	#$00
    759  f373				   .storeLeftIdx
    760  f373		       85 f1		      sta	PlayerLauncherIdx
    761  f375		       4c 8c f3 	      jmp	.storeCurrentInput
    762  f378
    763  f378				   .rightOnRelease
    764  f378		       18		      clc
    765  f379		       a5 f1		      lda	PlayerLauncherIdx
    766  f37b		       69 03		      adc	#CONS_LAUNCHER_IDX_STEP
    767  f37d		       c9 15		      cmp	#$15
    768  f37f		       90 02		      bcc	.storeRightIdx
    769  f381		       a9 12		      lda	#$12
    770  f383				   .storeRightIdx
    771  f383		       85 f1		      sta	PlayerLauncherIdx
    772  f385		       4c 8c f3 	      jmp	.storeCurrentInput
    773  f388
    774  f388				   .fireOnRelease
    775  f388		       a9 01		      lda	#CONS_PLAYER_STATE_MOVING
    776  f38a		       85 f0		      sta	PlayerState
    777  f38c				   .storeCurrentInput
    778  f38c		       a5 f2		      lda	PlayerInputSettings
    779  f38e		       85 f3		      sta	PlayerInputSettings+1
    780  f390				   .endJoystickCheck
