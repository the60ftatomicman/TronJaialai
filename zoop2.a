BlockQueue_Bot_1 .DS  #CONS_BQ_VERT_COLS
	org $C8
BlockQueue_Bot_2 .DS  #CONS_BQ_VERT_COLS
	org $D8
BlockQueue_Bot_3 .DS  #CONS_BQ_VERT_COLS
	org $E8
BlockQueue_Bot_4 .DS  #CONS_BQ_VERT_COLS
