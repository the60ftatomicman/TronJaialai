    lda #CONS_COLOR_ORANGE
    sta BlockQueue_Bot_1,y
    lda #CONS_COLOR_RED
    sta BlockQueue_Bot_2,y
    lda #CONS_COLOR_ORANGE
    sta BlockQueue_Bot_3,y    
    lda #CONS_COLOR_RED
    sta BlockQueue_Bot_4,y
    
    jmp Kernal_Temp_Next
Kernal_Temp_B
    ;TOP
