    jmp NextFrame
GotoStart
    jmp Start
;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;
;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;
;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;
; On Frame Code segment

NextFrame
    lsr SWCHB    ; test Game Reset switch
    bcc GotoStart    ; reset?

; 1 + 3 lines of VSYNC
    VERTICAL_SYNC

;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;
; 37 lines of underscan

    TIMER_SETUP 37
    
;;;;;;;;;;;;;;;;;;;;;;;
; Set Positions
    sta WSYNC
;;;;;;;;;;;;;;;;;;;;;;;
; Set Player X -- todo make this a pointer and data table affair.
    ldy Player0Pos_Col
    LOAD_POINTER_WITH_DATA Player0Pos_Ptr,PlayerPositions_Columns
    lda (Player0Pos_Ptr),y
    ldx #0           ; player 0
    jsr SetHorizPos
    nop
    TIMER_WAIT

;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;
; 192 lines of frame

    TIMER_SETUP 192
;;;;;;;;;;;;;;;;;;;;;;;
    lda #%00000000
    sta CTRLPF
    lda #$14
    sta COLUPF
    lda #$11
    sta COLUBK

    lda #$05
    sta Score
    lda #$00
    ldy Score
Kernal_PreScore.loop
    clc
    adc #$03
    dey
    bpl Kernal_PreScore.loop
    adc Score
    sta NumberIdx
    WYSNC_REPEATER 1
    tax
    ldy #$06
Kernal_Score
    lda Score_Numbers,x
    and $0f
    WYSNC_REPEATER 1
    sta PF1
    SLEEP 32
    lda Score_Numbers,x
    and $0f
    sta PF1
    ; --- doubles our values so instead of 6 it's 12 and more legable
    WYSNC_REPEATER 1
    dex
    dey
    bne Kernal_Score
    WYSNC_REPEATER 1
    lda #$00
    sta PF1
    WYSNC_REPEATER 2
    lda #CONS_COLOR_BLACK
    sta COLUPF
    sta COLUBK
    WYSNC_REPEATER 2
;;;;;;;;;;;;;;;;;;;;;;;
    lda #%00000001
    sta CTRLPF
    lda #CONS_GRID_BRICKS_BG
    sta COLUPF
    
    lda #%11110000
    sta PF0
    lda #%11100111
    sta PF1
    lda #%01111001
    sta PF2
    
    lda #$00
    ldx #CONS_BQ_VERT_ROWS-1
    sta WSYNC
Kernal_TopBlocks
    ;TODO -- honsetly do I need this? Could just try to use the X value!
    ldy #CONS_BQ_VERT_ROW_HEIGHT
Kernal_TopBlocks.Rows
    sta WSYNC
    
    lda BlockQueue_Top_0,x
    sta COLUBK
    
    SLEEP 23
    
    lda BlockQueue_Top_1,x
    sta COLUBK
    
    lda BlockQueue_Top_2,x
    sta COLUBK

    lda BlockQueue_Top_3,x
    sta COLUBK

    nop
    
    lda BlockQueue_Top_4,x
    sta COLUBK

    dey
    bne Kernal_TopBlocks.Rows
    
    nop
    lda #CONS_COLOR_BLACK
    sta COLUBK
    sta WSYNC
    
    dex
    bpl Kernal_TopBlocks
;;;;;;;;;;;;;;;;;;;;;;;
    sta WSYNC
    
    lda #%00000000
    sta PF0
    lda #%00011000
    sta PF1
    lda #%10000110
    sta PF2
    lda #CONS_GRID_CLIFF_BG
    sta CliffColor
    
    lda #CONS_COLOR_BLACK
    sta COLUPF
    ldy #CONS_CLIFF_HEIGHT
Kernal_Cliff_Top
    lda CliffColor
    sta COLUBK
    sec
    sbc #01
    sta CliffColor
    ldx #CONS_CLIFF_SHADING_GAP
Kernal_Cliff_Top.ColorBandLoop
    sta WSYNC
    dex 
    bne Kernal_Cliff_Top.ColorBandLoop
    dey
    bne Kernal_Cliff_Top
    WYSNC_REPEATER 1
    lda #CONS_COLOR_BLACK
    sta COLUBK
    WYSNC_REPEATER 1
;;;;;;;;;;;;;;;;;;;;;;;
    
    lda #%00000001
    sta CTRLPF
    lda #CONS_PLAYERZONE_PF
    sta COLUPF
    
    lda #%11110000
    sta PF0
    lda #%11111001
    sta PF1
    lda #%01110011
    sta PF2
    
    lda Player0_Color
    sta COLUP0
    
    lda #CONS_PLAYERZ_ROWS
    sta LoopIdx
    ldx #00
Kernal_PlayerZone
    ldy #CONS_PLAYERZ_ROW_HEIGHT
    
Kernal_PlayerZone.Rows
    sta WSYNC
    lda #CONS_COLOR_WHITE
    sta COLUBK


Kernal_PlayerZone.PlayerLogic.ComparePlayer
    lda Player0Pos_Row
    cmp LoopIdx
    bne Kernal_PlayerZone.SkipPlayer 
Kernal_PlayerZone.DrawPlayer
    lda #$FF
    jmp Kernal_PlayerZone.EndPlayer
Kernal_PlayerZone.SkipPlayer 
    lda #$00
Kernal_PlayerZone.EndPlayer
    sta GRP0 
    dey
    bne Kernal_PlayerZone.Rows
    sta WSYNC
    lda #CONS_COLOR_BLACK
    sta COLUBK
    lda #$00
    sta GRP0
    
    inx
    sta WSYNC

    dec LoopIdx
    bne Kernal_PlayerZone
;;;;;;;;;;;;;;;;;;;;;;;
    sta WSYNC
    
    lda #%00000000
    sta PF0
    lda #%00011000
    sta PF1
    lda #%10000110
    sta PF2

    lda #CONS_COLOR_BLACK
    sta COLUBK
    WYSNC_REPEATER 1

    lda CliffColor
    sta COLUBK
    
    lda #CONS_COLOR_BLACK
    sta COLUPF
    ldy #CONS_CLIFF_HEIGHT
Kernal_Cliff_Bot
    lda CliffColor
    sta COLUBK
    clc
    adc #01
    sta CliffColor
    ldx #CONS_CLIFF_SHADING_GAP
Kernal_Cliff_Bot.ColorBandLoop
    sta WSYNC
    dex 
    bne Kernal_Cliff_Bot.ColorBandLoop
    dey
    bne Kernal_Cliff_Bot
    lda #CONS_COLOR_BLACK
    sta COLUBK
    WYSNC_REPEATER 1
;;;;;;;;;;;;;;;;;;;;;;;
    lda #%00000001
    sta CTRLPF
    lda #CONS_GRID_BRICKS_BG
    sta COLUPF
    
    lda #%11110000
    sta PF0
    lda #%11100111
    sta PF1
    lda #%01111001
    sta PF2
    
    lda #$00
    ldx #00
    sta WSYNC
Kernal_BotBlocks
    ;TODO -- honsetly do I need this? Could just try to use the X value!
    ldy #CONS_BQ_VERT_ROW_HEIGHT
Kernal_BotBlocks.Rows
    sta WSYNC
    
    lda BlockQueue_Bot_0,x
    sta COLUBK
    
    SLEEP 23
    
    lda BlockQueue_Bot_1,x
    sta COLUBK
    
    lda BlockQueue_Bot_2,x
    sta COLUBK

    lda BlockQueue_Bot_3,x
    sta COLUBK

    nop
    
    lda BlockQueue_Bot_4,x
    sta COLUBK

    dey
    bne Kernal_BotBlocks.Rows
    
    nop
    lda #CONS_COLOR_BLACK
    sta COLUBK
    sta WSYNC
    
    inx
    txa
    cmp #CONS_BQ_VERT_ROWS
    bmi Kernal_BotBlocks
;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;
Kernal_StopVisuals
    lda #00
    sta GRP0
    sta GRP1
    sta ENAM0
    sta ENAM1
    
    lda #CONS_COLOR_BLACK
    sta COLUBK
    sta COLUPF
    lda #%00000000
    sta PF0
    lda #%00000000
    sta PF1
    lda #%00000000
    sta PF2
;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;
Kernal_Inputs
    jsr ReadJoystick
    jsr setBlockQueueIdx ; TODO -- maybe move this into that 10 line gap we have after drawing top blocks?
;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;
Kernal_WaitTilEnd
    nop  ; at: 189 of 233 lines by this point, dont cross! note in PIA will be 232 if right.
    TIMER_WAIT
;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;
; 29 lines of overscan
Kernal_Overscan
    TIMER_SETUP 29
    nop
    TIMER_WAIT

; total = 262 lines, go to next frame
    jmp NextFrame

;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;
;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;
;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;
; Subroutines
SetPositionMissles 
    sta WSYNC
    lda #46 ;#46
    ldx #2           ; player 0 Missle
    jsr SetHorizPos

    sta WSYNC
    lda #62
    ldx #3           ; player 1 Missle
    jsr SetHorizPos
    rts
;;;;;;;;;;;;;;;;;;;;;;;    
; A = X coordinate
; X = player number (0 or 1)
SetHorizPos
        sta WSYNC	; start a new line
        sec		; set carry flag
SetHorizPos.1
	sbc #15		; subtract 15
	bcs SetHorizPos.1 ; branch until negative
	eor #7		; calculate fine offset
        asl
        asl
        asl
        asl
        sta RESP0,x	; fix coarse position
        sta HMP0,x	; set fine offset
        sta WSYNC
        sta HMOVE	; apply the previous fine position(s)
	sta HMCLR	; reset the old horizontal position(s)
        rts		; return to caller
;;;;;;;;;;;;;;;;;;;;;;;    
; 
handleFireButton
    ; -- we need to be able to go to the 
    lda Player0Pos_Row
    cmp #$02
    beq .handleFireButton.NoAction
    
    LOAD_POINTER_WITH_DATA BlockQueue_Addr_Ptr,PlayerColMemAddresses
    ldy BlockQueue_Idx
    lda (BlockQueue_Addr_Ptr),y
    sta BlockQueue_Data_Ptr
    lda #>00
    sta BlockQueue_Data_Ptr+1

    ldy #00 
.handleFireButton.FindRowMem
    tya
    cmp #CONS_BQ_VERT_ROW_HEIGHT ; if we are at our limit, goto the END
    beq .handleFireButton.NoAction
    ; --- now look at blocks
    tay
    lda (BlockQueue_Data_Ptr),y
    cmp #CONS_COLOR_BLACK  ; ----------    is empty
    beq .handleFireButton.gotoNextBlock
    cmp  Player0_Color  ; ----------    is player color
    beq .handleFireButton.MatchingColor
    jmp .handleFireButton.swapWithBlock
.handleFireButton.MatchingColor
    ; here we will loop through the columns blacking out all of the
    lda #CONS_COLOR_BLACK
    sta (BlockQueue_Data_Ptr),y
.handleFireButton.gotoNextBlock
    iny
    bcs .handleFireButton.FindRowMem
.handleFireButton.swapWithBlock
    lda (BlockQueue_Data_Ptr),y
    sta TempByte
    lda Player0_Color
    sta (BlockQueue_Data_Ptr),y
    lda TempByte
    sta Player0_Color
.handleFireButton.NoAction
    rts
;;;;;;;;;;;;;;;;;;;;;;;    
; 
; 
setBlockQueueIdx
    ; we will set the BlockQueue_Idx to point to the proper index
    ;lda Player0Pos_Col ; maybe lessen this by ALWAYS adding this to our blockqueue?
    ;sta BlockQueue_Idx
    ; rows count from bottom UP apparently! starting at 1. my bad?
    ldy #$00
    lda Player0Pos_Row
    cmp #01
    bne .setBlockQueueIdx.noRowChange
    REPEAT CONS_BQ_VERT_COLS
        iny
    REPEND 
.setBlockQueueIdx.noRowChange
    tya
    clc
    adc Player0Pos_Col
    sta BlockQueue_Idx
    rts
;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;
;-----------------------------------------
; SWCHA -- directional register
; #%10000000 -- P1 Right
; #%01000000 -- P1 left
; #%00100000 -- P1 down
; #%00010000 -- P1 up
; #%00001000 -- P0 Right
; #%00000100 -- P0 left
; #%00000010 -- P0 down
; #%00000001 -- P0 up
ReadJoystick
      lda #%00000000
      sta Player0_InputSettings  ; Set current input state to 0
.ReadJoystick
; ----------------------
; LEFT
; ----------------------
      lda #%01000000
      bit SWCHA
      bne .checkRight

      lda Player0_InputSettings
      ora #%00000001
      sta Player0_InputSettings

; ----------------------
; RIGHT
; ----------------------
.checkRight
      lda #%10000000
      bit SWCHA
      bne .checkUp

      lda Player0_InputSettings
      ora #%00000010
      sta Player0_InputSettings

; ----------------------
; UP
; ----------------------
.checkUp
      lda #%00010000
      bit SWCHA
      bne .checkDown

      lda Player0_InputSettings
      ora #%00001000
      sta Player0_InputSettings

; ----------------------
; DOWN
; ----------------------
.checkDown
      lda #%00100000
      bit SWCHA
      bne .checkbutton

      lda Player0_InputSettings
      ora #%00010000
      sta Player0_InputSettings
      
.checkbutton
      bit INPT4
      bmi .determineJoystickAction ; released
      lda Player0_InputSettings
      ora #%00000100
      sta Player0_InputSettings
      
.determineJoystickAction
        lda Player0_InputSettings
        bne .storeCurrentInput
        lda Player0_InputSettings+1
        beq .storeCurrentInput

        tax
        ; Fire on release
        and #%00000100
        bne .fireOnRelease

; LEFT RELEASE
      txa
      and #%00000001
      bne .leftOnRelease

; RIGHT RELEASE
      txa
      and #%00000010
      bne .rightOnRelease

; UP RELEASE
      txa
      and #%00001000
      bne .upOnRelease

; DOWN RELEASE
      txa
      and #%00010000
      bne .downOnRelease
.leftOnRelease
    lda Player0Pos_Col
    cmp #$00
    beq .storeCurrentInput
    dec Player0Pos_Col
    jmp .storeCurrentInput
.rightOnRelease
    lda Player0Pos_Col
    cmp #CONS_PLAYERZ_COLS-2
    beq .storeCurrentInput
    inc Player0Pos_Col
    jmp .storeCurrentInput
.upOnRelease
    lda Player0Pos_Row
    cmp #CONS_PLAYERZ_ROWS
    beq .storeCurrentInput
    inc Player0Pos_Row
    jmp .storeCurrentInput
.downOnRelease
    lda Player0Pos_Row
    cmp #$01
    beq .storeCurrentInput
    dec Player0Pos_Row
    jmp .storeCurrentInput
.fireOnRelease
    jsr handleFireButton
.storeCurrentInput
    lda Player0_InputSettings
    sta Player0_InputSettings+1
.endJoystickCheck
      rts

;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;
;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;
