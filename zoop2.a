    org $f000

Start
    CLEAN_START
;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;
; Lets build some mock data for the blocks

;;;;;;;;;;;;;;;;;;;;;;;
    lda #$00
    sta TempByte


    ldy #$00
Kernal_Temp_Rows
    FLIP_BOOL TempByte
    bne Kernal_Temp_B
Kernal_Temp_A
    lda #CONS_COLOR_ORANGE
    sta BlockQueue_Top_0,y
    lda #CONS_COLOR_RED
    sta BlockQueue_Top_1,y
    lda #CONS_COLOR_ORANGE
    sta BlockQueue_Top_2,y
    lda #CONS_COLOR_RED
    sta BlockQueue_Top_3,y    
    lda #CONS_COLOR_ORANGE
    sta BlockQueue_Top_4,y
    lda #CONS_COLOR_RED
    sta BlockQueue_Top_5,y  
    
    jmp Kernal_Temp_Next
Kernal_Temp_B
    lda #CONS_COLOR_RED
    sta BlockQueue_Top_0,y
    lda #CONS_COLOR_ORANGE
    sta BlockQueue_Top_1,y
    lda #CONS_COLOR_RED
    sta BlockQueue_Top_2,y
    lda #CONS_COLOR_ORANGE
    sta BlockQueue_Top_3,y    
    lda #CONS_COLOR_RED
    sta BlockQueue_Top_4,y
    lda #CONS_COLOR_ORANGE
    sta BlockQueue_Top_5,y
Kernal_Temp_Next
    iny
    tya
    cmp #CONS_BQ_VERT_ROWS
    bcc Kernal_Temp_Rows
; -- just shows us the LAST value
    lda #$FF
    sta BlockQueue_Top_5,y
;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;
; Setup Other Player Things
    lda #$00
    sta Player0Pos_Col
    
    lda #$02
    sta Player0Pos_Row
;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;
;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;
;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;
; On Frame Code segment

NextFrame
    lsr SWCHB    ; test Game Reset switch
    bcc Start    ; reset?

; 1 + 3 lines of VSYNC
    VERTICAL_SYNC

;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;
; 37 lines of underscan

    TIMER_SETUP 37
    
;;;;;;;;;;;;;;;;;;;;;;;
; Set Positions
    sta WSYNC
    lda #20
    ldx #0           ; player 0
    jsr SetHorizPos
    
    jsr SetPositionMissles
;;;;;;;;;;;;;;;;;;;;;;;
; Set Player X -- todo make this a pointer and data table affair.
    lda Player0Pos_Col
.setPlayerCol_Zero
    cmp #$00
    bne .setPlayerCol_One
    lda #%11110110
    sta Player0Pos_PF_Left1
    lda #%00000000
    sta Player0Pos_PF_Left2
    sta Player0Pos_PF_Right0
    sta Player0Pos_PF_Right1
    
    jmp .setPlayerCol_Done
.setPlayerCol_One
    cmp #$01
    bne .setPlayerCol_Two
    lda #%11110000
    sta Player0Pos_PF_Left1
    lda #%00000110
    sta Player0Pos_PF_Left2
    lda #%00000000
    sta Player0Pos_PF_Right0
    sta Player0Pos_PF_Right1
    jmp .setPlayerCol_Done
.setPlayerCol_Two
    cmp #$02
    bne .setPlayerCol_Three
    lda #%11110000
    sta Player0Pos_PF_Left1
    lda #%01100000
    sta Player0Pos_PF_Left2
    lda #%00000000
    sta Player0Pos_PF_Right0
    sta Player0Pos_PF_Right1
    jmp .setPlayerCol_Done
.setPlayerCol_Three
    cmp #$03
    bne .setPlayerCol_Four
    lda #%11110000
    sta Player0Pos_PF_Left1
    lda #%01100000
    sta Player0Pos_PF_Right0
    lda #%00000000
    sta Player0Pos_PF_Left2
    sta Player0Pos_PF_Right1
    jmp .setPlayerCol_Done
.setPlayerCol_Four
    cmp #$04
    bne .setPlayerCol_Five
    lda #%11110000
    sta Player0Pos_PF_Left1
    lda #%01100000
    sta Player0Pos_PF_Right1
    lda #%00000000
    sta Player0Pos_PF_Left2
    sta Player0Pos_PF_Right0
    jmp .setPlayerCol_Done
.setPlayerCol_Five
    lda #%11110000
    sta Player0Pos_PF_Left1
    lda #%00000110
    sta Player0Pos_PF_Right1
    lda #%00000000
    sta Player0Pos_PF_Left2
    sta Player0Pos_PF_Right0

.setPlayerCol_Done
    nop
    TIMER_WAIT

;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;
; 192 lines of frame

    TIMER_SETUP 192
;;;;;;;;;;;;;;;;;;;;;;;
    lda #%01110110
    sta NUSIZ0
    sta NUSIZ1
    
    lda #%00000001
    sta CTRLPF
    lda #CONS_COLOR_BLACK
    sta COLUPF
    
    lda #%00000000
    sta PF0
    lda #%00000000
    sta PF1
    lda #%00000000
    sta PF2
;;;;;;;;;;;;;;;;;;;;;;;
    ;TODO only kept here because we may put stuff above htis. think of it as just safegaurding for now
    lda #%00000000
    sta PF0
    lda #%00000000
    sta PF1
    lda #%00000000
    sta PF2
    
    lda #$00
    ldx #CONS_BQ_VERT_ROWS
    sta WSYNC
Kernal_TopBlocks
    ;TODO -- honsetly do I need this? Could just try to use the X value!
    ldy #CONS_BQ_VERT_ROW_HEIGHT
Kernal_TopBlocks.Rows
    sta WSYNC
    lda #%11111111
    sta ENAM0
    sta ENAM1
    
    SLEEP 16 ; 16 with web, 17 with stella
    
    ;lda #CONS_COLOR_RED
    lda BlockQueue_Top_0,x
    sta COLUP0

    ;lda #CONS_COLOR_ORANGE
    lda BlockQueue_Top_1,x
    sta COLUP1
    
    ;lda #CONS_COLOR_YELLOW
    lda BlockQueue_Top_2,x
    sta COLUP0
    
    ;lda #CONS_COLOR_GREEN
    lda BlockQueue_Top_3,x
    sta COLUP1


    ;lda #CONS_COLOR_PURPLE
    lda BlockQueue_Top_4,x
    sta COLUP0
    
    ;lda #CONS_COLOR_TEAL
    lda BlockQueue_Top_5,x
    sta COLUP1

    dey
    bne Kernal_TopBlocks.Rows
    
    lda #CONS_COLOR_BLACK
    sta COLUP0
    sta COLUP1
    
    dex
    bpl Kernal_TopBlocks

;;;;;;;;;;;;;;;;;;;;;;;
    ;sta WSYNC
    lda #%01100000
    sta HMM0
    sta HMM1
    sta WSYNC
    sta HMOVE 
    lda #%00100110
    sta NUSIZ0
    sta NUSIZ1
    
    lda #%00000000
    sta CTRLPF
   
    ; one time
    lda #CONS_COLOR_BLACK
    sta COLUPF
    
    lda #CONS_PLAYERZ_ROWS
    sta LoopIdx
    ldx #00
Kernal_PlayerZone
    ldy #CONS_PLAYERZ_ROW_HEIGHT
    


Kernal_PlayerZone.Rows
    sta WSYNC

    lda #CONS_COLOR_WHITE
    sta COLUBK
    
    lda #%11110000
    sta PF0
; 1 == bot, increases as we go up.    
Kernal_PlayerZone.PlayerLogic_Left
    lda Player0Pos_Row
    cmp LoopIdx
    bne Kernal_PlayerZone.SkipPlayer_Left 
Kernal_PlayerZone.DrawPlayer_Left
    lda Player0Pos_PF_Left1
    sta PF1
    lda Player0Pos_PF_Left2
    sta PF2
    
Kernal_PlayerZone.ColorPlayer_Color
    lda Player0_Color;#CONS_COLOR_TEAL
    sta COLUPF

Kernal_PlayerZone.DrawPlayer_Right    
    lda Player0Pos_PF_Right0
    sta PF0
    lda Player0Pos_PF_Right1
    sta PF1  
    lda #%11111111
    sta PF2
    SLEEP 4
    
   jmp Kernal_PlayerZone.EndLine
Kernal_PlayerZone.SkipPlayer_Left
    lda #%11110000
    sta PF1
    lda #%000000000
    sta PF2
    SLEEP 4
    
Kernal_PlayerZone.SkipPlayer_Right        
    lda #%00000000
    sta PF0
    lda #%00000000
    sta PF1  
    lda #%11111111
    sta PF2
    
   
Kernal_PlayerZone.EndLine    
    lda #CONS_COLOR_BLACK
    sta COLUPF
    
    dey
    bne Kernal_PlayerZone.Rows
    sta WSYNC
    ;Turn off graphics for a line didider
    lda #CONS_COLOR_BLACK
    sta COLUBK
    
    inx
    sta WSYNC

    dec LoopIdx
    bne Kernal_PlayerZone

;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;
Kernal_WaitTilEnd
    jsr handleFireButton
    lda #00
    sta GRP0
    sta GRP1
    sta ENAM0
    sta ENAM1
    
    lda #CONS_COLOR_BLACK
    sta COLUPF
    lda #%00000000
    sta PF0

    lda #%00000000
    sta PF1

    lda #%00000000
    sta PF2


    jsr ReadJoystick
    TIMER_WAIT

;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;
; 29 lines of overscan

    TIMER_SETUP 29
    TIMER_WAIT

; total = 262 lines, go to next frame
    jmp NextFrame

;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;
;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;
;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;
; Subroutines
SetPositionMissles
    sta WSYNC
    lda #30
    ldx #1           ; player 1
    jsr SetHorizPos  
    
    sta WSYNC
    lda #46
    ldx #2           ; player 0 Missle
    jsr SetHorizPos

    sta WSYNC
    lda #62
    ldx #3           ; player 1 Missle
    jsr SetHorizPos
    rts
;;;;;;;;;;;;;;;;;;;;;;;    
; A = X coordinate
; X = player number (0 or 1)
SetHorizPos
        sta WSYNC	; start a new line
        sec		; set carry flag
SetHorizPos.1
	sbc #15		; subtract 15
	bcs SetHorizPos.1 ; branch until negative
	eor #7		; calculate fine offset
        asl
        asl
        asl
        asl
        sta RESP0,x	; fix coarse position
        sta HMP0,x	; set fine offset
        sta WSYNC
        sta HMOVE	; apply the previous fine position(s)
	sta HMCLR	; reset the old horizontal position(s)
        rts		; return to caller
;;;;;;;;;;;;;;;;;;;;;;;    
; 
; To redo -- this will be easier with 
handleFireButton
    ldy Player0Pos_Col
    iny
    lda #((CONS_BQ_VERT_ROWS-2)*CONS_BQ_VERT_COLS)
    clc
.handleFireButton.FindColMem
    adc #$01
    dey
    bne .handleFireButton.FindColMem
    ldx CONS_BQ_VERT_COLS
    tay
.handleFireButton.FindRowMem
   ; TODO -- this obviously becomes more complicated once we know what ROW we are looking at!
    lda BlockQueue_Top_0,y
    cmp #00
    bne .handleFireButton.storeColor
    REPEAT CONS_BQ_VERT_COLS
    dey
    REPEND
    dex
    bne .handleFireButton.FindRowMem
.handleFireButton.storeColor
    sta Player0_Color
    rts 
;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;
;-----------------------------------------
; SWCHA -- directional register
; #%10000000 -- P1 Right
; #%01000000 -- P1 left
; #%00100000 -- P1 down
; #%00010000 -- P1 up
; #%00001000 -- P0 Right
; #%00000100 -- P0 left
; #%00000010 -- P0 down
; #%00000001 -- P0 up
ReadJoystick
      lda #%00000000
      sta Player0_InputSettings  ; Set current input state to 0
.ReadJoystick
; ----------------------
; LEFT
; ----------------------
      lda #%01000000
      bit SWCHA
      bne .checkRight

      lda Player0_InputSettings
      ora #%00000001
      sta Player0_InputSettings

; ----------------------
; RIGHT
; ----------------------
.checkRight
      lda #%10000000
      bit SWCHA
      bne .checkUp

      lda Player0_InputSettings
      ora #%00000010
      sta Player0_InputSettings

; ----------------------
; UP
; ----------------------
.checkUp
      lda #%00010000
      bit SWCHA
      bne .checkDown

      lda Player0_InputSettings
      ora #%00001000
      sta Player0_InputSettings

; ----------------------
; DOWN
; ----------------------
.checkDown
      lda #%00100000
      bit SWCHA
      bne .checkbutton

      lda Player0_InputSettings
      ora #%00010000
      sta Player0_InputSettings
      
.checkbutton
      bit INPT4
      bmi .determineJoystickAction ; released
      lda Player0_InputSettings
      ora #%00000100
      sta Player0_InputSettings
      
.determineJoystickAction
        lda Player0_InputSettings
        bne .storeCurrentInput
        lda Player0_InputSettings+1
        beq .storeCurrentInput

        tax
        ; Fire on release
        and #%00000100
        bne .fireOnRelease

; LEFT RELEASE
      txa
      and #%00000001
      bne .leftOnRelease

; RIGHT RELEASE
      txa
      and #%00000010
      bne .rightOnRelease

; UP RELEASE
      txa
      and #%00001000
      bne .upOnRelease

; DOWN RELEASE
      txa
      and #%00010000
      bne .downOnRelease
.leftOnRelease
	lda Player0Pos_Col
        cmp #$00
        beq .storeCurrentInput
	dec Player0Pos_Col
        jmp .storeCurrentInput
.rightOnRelease
	lda Player0Pos_Col
        cmp #CONS_PLAYERZ_COLS-1
        beq .storeCurrentInput
	inc Player0Pos_Col
        jmp .storeCurrentInput
.upOnRelease
	lda Player0Pos_Row
        cmp #CONS_PLAYERZ_ROWS
        beq .storeCurrentInput
	inc Player0Pos_Row
        jmp .storeCurrentInput
.downOnRelease
	lda Player0Pos_Row
        cmp #$01
        beq .storeCurrentInput
	dec Player0Pos_Row
        jmp .storeCurrentInput
.fireOnRelease
	;lda Player0Pos_X
    ;    sta Player0Missle_X
    ;    lda #$50
    ;    sta Player0Missle_Y
.storeCurrentInput
        lda Player0_InputSettings
        sta Player0_InputSettings+1
.endJoystickCheck
      rts

