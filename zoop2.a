; On Frame Code segment

NextFrame
    lsr SWCHB    ; test Game Reset switch
    bcc GotoStart    ; reset?

; 1 + 3 lines of VSYNC
    VERTICAL_SYNC

;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;
; 37 lines of underscan

    TIMER_SETUP 37
    
;;;;;;;;;;;;;;;;;;;;;;;
; Set Positions
    sta WSYNC
;;;;;;;;;;;;;;;;;;;;;;;
; Set Player X -- todo make this a pointer and data table affair.
    ldy Player0Pos_Col
    LOAD_POINTER_WITH_DATA Player0Pos_Ptr,PlayerPositions_Columns
    lda (Player0Pos_Ptr),y
    ldx #0           ; player 0
    jsr SetHorizPos
    sta WSYNC
    lda #CONS_SCORE_LEFTMOST_DIGIT_X
    ldx #1           ; player 1
    jsr SetHorizPos
    sta WSYNC
    lda #CONS_SCORE_MINUS_SIGN_X
    ldx #02 ; player 0 missle
    jsr SetHorizPos
    nop
    TIMER_WAIT

;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;
; 192 lines of frame

    TIMER_SETUP 192
;;;;;;;;;;;;;;;;;;;;;;;
    ; vv just for testing
    lda #$01 
    sta ScoreNeg
    ; ^^ just for testing
    lda #%0110000
    sta NUSIZ0
    lda #%1000110
    sta NUSIZ1
    lda #CONS_COLOR_BLACK
    sta COLUP0
    sta COLUP1
    
    WYSNC_REPEATER 1
    lda ScoreNeg
    bne Kernal_PreScore.isNegativeColor
Kernal_PreScore.isPositiveColor
    lda #CONS_SCORE_POSITIVE
    sta COLUBK
    jmp Kernal_PreScore.getNibbles  
Kernal_PreScore.isNegativeColor    
    lda #CONS_SCORE_NEGATIVE
    sta COLUBK
Kernal_PreScore.getNibbles    
    ; -- Always set the digit right nibble, we'll probably do this LATER in the code
    lda Score
    and #$0F
    sta Score
    lda Score+1
    and #$0F
    sta Score+1
    lda Score+2
    and #$0F
    sta Score+2
    ;-- loop over EVERY digit
    
    ldx #02
Kernal_PreScore.setNumAddresses
    ldy Score,x
    clc
    lda #$05 ; 0 ALWAYS starts at 5
Kernal_PreScore.loopaddress
    dey
    bmi Kernal_PreScore.addTempByte
    adc #$06
    jmp Kernal_PreScore.loopaddress
Kernal_PreScore.addTempByte  
    sta NumberIdx,x
    dex
    bpl Kernal_PreScore.setNumAddresses
    ;----------------
    ldy #$06
Kernal_Score
    WYSNC_REPEATER 1
    lda ScoreNeg
    beq Kernal_Score.extraDelay
    lda Minus_Sign,y
    sta ENAM0
    jmp Kernal_Score.printDigits
Kernal_Score.extraDelay
    SLEEP 9
Kernal_Score.printDigits
    SLEEP 7
    ldx NumberIdx+2
    lda Score_Numbers,x
    sta GRP1

    ldx NumberIdx+1
    lda Score_Numbers,x
    sta GRP1
    
    ldx NumberIdx
    lda Score_Numbers,x
    sta GRP1

    dec NumberIdx
    dec NumberIdx+1
    dec NumberIdx+2
    
    lda #$00
    sta GRP1
    WYSNC_REPEATER 1; -- todo why is this SO angry!
    
    dey
    bne Kernal_Score
Kernal_Score.lowerBuffer
    WYSNC_REPEATER 1
    lda #$00
    sta GRP1
    sta ENAM0
    WYSNC_REPEATER 2
    lda #CONS_COLOR_BLACK
    sta COLUPF
    sta COLUBK
    WYSNC_REPEATER 2
;;;;;;;;;;;;;;;;;;;;;;;
    lda #%00000001
    sta CTRLPF
    lda #CONS_GRID_BRICKS_BG
    sta COLUPF
    
    lda #%11110000
    sta PF0
    lda #%11100111
    sta PF1
    lda #%01111001
    sta PF2
    
    lda #$00
    ldx #CONS_BQ_VERT_ROWS-1
    sta WSYNC
Kernal_TopBlocks
    ;TODO -- honsetly do I need this? Could just try to use the X value!
    ldy #CONS_BQ_VERT_ROW_HEIGHT
Kernal_TopBlocks.Rows
    sta WSYNC
    
    lda BlockQueue_Top_0,x
    sta COLUBK
    
    SLEEP 23
    
    lda BlockQueue_Top_1,x
    sta COLUBK
    
    lda BlockQueue_Top_2,x
