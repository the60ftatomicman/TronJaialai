;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;
; Constants segment
; ---- COLORS
CONS_COLOR_BLACK  EQU $00
CONS_COLOR_LGREY  EQU #04
CONS_COLOR_GREY_C EQU $0C
CONS_COLOR_GREY_7 EQU $07
CONS_COLOR_GREY   EQU $02
CONS_COLOR_WHITE  EQU $0E

CONS_COLOR_RED    EQU $46
CONS_COLOR_ORANGE EQU $38
CONS_COLOR_YELLOW EQU $1E
CONS_COLOR_GREEN  EQU $C6
CONS_COLOR_BLUE   EQU $A6
CONS_COLOR_PURPLE EQU $64

CONS_COLOR_PINK   EQU $3C
CONS_COLOR_TEAL   EQU $8D
CONS_COLOR_CHART  EQU $CA
; ---- COLOR MAPPING TO OBJECT
CONS_GRID_BRICKS_BG EQU CONS_COLOR_GREY_C
CONS_GRID_CLIFF_BG  EQU CONS_COLOR_GREY_7
CONS_PLAYERZONE_PF  EQU CONS_COLOR_GREY
;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;
;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;
;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;
; Macros
;--------
; FLIP_BOOL
; Original author: Andy Garber
; Takes a memory address and flips it's value than stores it
; Assumes the Memory address value is 1 or 0
; usage: FLIP_BOOL SomeAddress
    MAC FLIP_BOOL
.MEMADDR     SET {1}
    lda .MEMADDR
    EOR #$01
    sta .MEMADDR
    ENDM

;--------
; LOAD_POINTER_WITH_DATA
; Original author: Andy Garber
; Loads a pointer with low byte than high byte address of data object
; usage: LOAD_POINTER_WITH_DATA pointer data
    MAC LOAD_POINTER_WITH_DATA
.POINTER      SET {1}
.DATA_BLOB    SET {2}
    lda #<.DATA_BLOB
    sta .POINTER
    lda #>.DATA_BLOB
    sta .POINTER+1
    ENDM
;--------
; WYSNC_REPEATER
; Original author: Andy Garber
; just a wrapper around REPEAT X lines of WSYNC. used to help with spacing in this game.
    MAC WYSNC_REPEATER
.LINES_TO_WAIT SET {1}
    REPEAT .LINES_TO_WAIT
        sta WSYNC
    REPEND
    ENDM
    
;--------
; SET_BLOCK_COLUMNS
; Original author: Andy Garber
; easy way to set my column counts
    MAC SET_BLOCK_COLUMNS
.COLUMN_COUNT SET {1}
    IF .COLUMN_COUNT = 6
        lda #%01110110
        sta NUSIZ0
        sta NUSIZ1
    ELSE
        IF .COLUMN_COUNT = 5
            lda #%01110110
            sta NUSIZ0
            lda #%01110010
            sta NUSIZ1
        ELSE
            IF .COLUMN_COUNT = 4
                lda #%01110010
                sta NUSIZ0
                sta NUSIZ1
            ELSE
                IF .COLUMN_COUNT = 3
                    lda #%01110010
                    sta NUSIZ0
                    lda #%01110001
                    sta NUSIZ1
                ELSE
                    IF .COLUMN_COUNT = 2
                        lda #%01110000
                        sta NUSIZ0
                        sta NUSIZ1
                    ELSE
                        ECHO "ERROR: SET_BLOCK_COLUMNS only supports 6-2"
                        ERR
                    ENDIF
                ENDIF
            ENDIF
        ENDIF
    ENDIF
    ENDM
