;;;;;;;;;;;;;;;;;;;;;;;
    sta WSYNC
    
    lda #%00000000
    sta PF0
    lda #%00011000
    sta PF1
    lda #%10000110
    sta PF2

    lda #CONS_COLOR_BLACK
    sta COLUBK
    WYSNC_REPEATER 1

    lda CliffColor
    sta COLUBK
    
    lda #CONS_COLOR_BLACK
    sta COLUPF
    ldy #CONS_CLIFF_HEIGHT
Kernal_Cliff_Bot
    lda CliffColor
    sta COLUBK
    clc
    adc #01
    sta CliffColor
    ldx #CONS_CLIFF_SHADING_GAP
Kernal_Cliff_Bot.ColorBandLoop
