    org $f000

Start
    CLEAN_START
;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;
; Lets build some mock data for the blocks

;;;;;;;;;;;;;;;;;;;;;;;
    lda #$00
    sta TempByte

    lda #$01
    sta Time+2
    lda #$00
    sta Time+1
    lda #$00
    sta Time

    ldy #$00
Kernal_Temp_Rows
    FLIP_BOOL TempByte
    bne Kernal_Temp_B
Kernal_Temp_A
    ;TOP
    lda #CONS_COLOR_ORANGE
    sta BlockQueue_Top_0,y
    lda #CONS_COLOR_ORANGE
    sta BlockQueue_Top_1,y
    lda #CONS_COLOR_ORANGE
    sta BlockQueue_Top_2,y
    lda #CONS_COLOR_RED
    sta BlockQueue_Top_3,y    
    lda #CONS_COLOR_ORANGE
    sta BlockQueue_Top_4,y
    ;BOT
    lda #CONS_COLOR_RED
