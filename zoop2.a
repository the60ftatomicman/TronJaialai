;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;
; Macros
;--------
; FLIP_BOOL
; Original author: Andy Garber
; Takes a memory address and flips it's value than stores it
; Assumes the Memory address value is 1 or 0
; usage: FLIP_BOOL SomeAddress
    MAC FLIP_BOOL
.MEMADDR     SET {1}
    lda .MEMADDR
    EOR #$01
    sta .MEMADDR
    ENDM

;--------
; LOAD_POINTER_WITH_DATA
; Original author: Andy Garber
; Loads a pointer with low byte than high byte address of data object
; usage: LOAD_POINTER_WITH_DATA pointer data
    MAC LOAD_POINTER_WITH_DATA
.POINTER      SET {1}
.DATA_BLOB    SET {2}
    lda #<.DATA_BLOB
    sta .POINTER
    lda #>.DATA_BLOB
    sta .POINTER+1
    ENDM


;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;
;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;
;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;
; Variables segment

    seg.u Variables
    org $80

TempByte .byte


CONS_BQ_VERT_COLS        EQU #5
CONS_BQ_VERT_ROWS        EQU #5
CONS_BQ_VERT_ROW_HEIGHT  EQU #8
;
CONS_BQ_HORI_COLS        EQU #5
CONS_BQ_HORI_ROWS        EQU #3
CONS_BQ_HORI_ROW_HEIGHT  EQU #8
;
CONS_PLAYERZ_COLS        EQU #6
CONS_PLAYERZ_ROWS        EQU #3
CONS_PLAYERZ_ROW_HEIGHT  EQU #9
;
Player0Pos_Col .byte
Player0Pos_Row .byte
Player0Pos_PF_Left1  .byte
Player0Pos_PF_Left2  .byte
Player0Pos_PF_Right0 .byte
Player0Pos_PF_Right1 .byte
Player0_Color  .byte
Player0_InputSettings .DS 2 ; 0 == current, 1 == previous
Player0Missle_X .byte
Player0Missle_Y .byte
;
CurrentScanline .byte
GameState .byte

BlockQueue_Ptr   .DS 2

	org $C0
BlockQueue_Top_0 .DS  #CONS_BQ_VERT_COLS
	org $C8
BlockQueue_Top_1 .DS  #CONS_BQ_VERT_COLS
	org $D0
BlockQueue_Top_2 .DS  #CONS_BQ_VERT_COLS
	org $D8
BlockQueue_Top_3 .DS  #CONS_BQ_VERT_COLS
	org $E0
BlockQueue_Top_4 .DS  #CONS_BQ_VERT_COLS
	org $E8
BlockQueue_Top_5 .DS  #CONS_BQ_VERT_COLS

LoopIdx .DS 2
