Score_Numbers
    ; ---- 00
    .byte #%01110111
    .byte #%01010101
    .byte #%01010101
    .byte #%01010101
    .byte #%01010101
    .byte #%01110111
    ; ---- 11
    .byte #%00000111
    .byte #%00000010
    .byte #%00000010
    .byte #%00000010
    .byte #%00000010
    .byte #%00000110
    ; ---- 22
    .byte #%00000111
    .byte #%00000100
    .byte #%00000100
    .byte #%00000011
    .byte #%00000001
    .byte #%00000111
    ; ---- 33
    .byte #%00000111
    .byte #%00000001
    .byte #%00000001
    .byte #%00000011
    .byte #%00000001
    .byte #%00000111
    ; ---- 44
    .byte #%00000001
    .byte #%00000001
    .byte #%00000011
    .byte #%00000111
    .byte #%00000101
    .byte #%00000101
    ; ---- 55
    .byte #%00000111
    .byte #%00000001
    .byte #%00000001
    .byte #%00000110
    .byte #%00000100
    .byte #%00000111
