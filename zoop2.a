    processor 6502
    include "vcs.h"
    include "macro.h"
    include "xmacro.h"
;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;
;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;
;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;
; Constants segment
; ---- COLORS
CONS_COLOR_BLACK  EQU $00
CONS_COLOR_LGREY  EQU #04
CONS_COLOR_GREY   EQU $E1
CONS_COLOR_WHITE  EQU $0E

CONS_COLOR_RED    EQU $46
CONS_COLOR_ORANGE EQU $38
CONS_COLOR_YELLOW EQU $1E
CONS_COLOR_GREEN  EQU $C6
CONS_COLOR_BLUE   EQU $A6
CONS_COLOR_PURPLE EQU $64

CONS_COLOR_PINK   EQU $3C
CONS_COLOR_TEAL   EQU $8D
CONS_COLOR_CHART  EQU $CA
; ---- COLOR MAPPING TO OBJECT
CONS_COLOR_OBJ_PLAYER_TILE_A EQU #CONS_COLOR_LGREY
CONS_COLOR_OBJ_PLAYER_TILE_B EQU #CONS_COLOR_WHITE


;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;
;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;
;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;
; Macros
;--------
; FLIP_BOOL
; Original author: Andy Garber
; Takes a memory address and flips it's value than stores it
; Assumes the Memory address value is 1 or 0
; usage: FLIP_BOOL SomeAddress
    MAC FLIP_BOOL
.MEMADDR     SET {1}
    lda .MEMADDR
    EOR #$01
    sta .MEMADDR
    ENDM

;--------
; LOAD_POINTER_WITH_DATA
; Original author: Andy Garber
; Loads a pointer with low byte than high byte address of data object
; usage: LOAD_POINTER_WITH_DATA pointer data
    MAC LOAD_POINTER_WITH_DATA
.POINTER      SET {1}
.DATA_BLOB    SET {2}
    lda #<.DATA_BLOB
    sta .POINTER
    lda #>.DATA_BLOB
    sta .POINTER+1
    ENDM
;--------
; WYSNC_REPEATER
; Original author: Andy Garber
; just a wrapper around REPEAT X lines of WSYNC. used to help with spacing in this game.
    MAC WYSNC_REPEATER
.LINES_TO_WAIT SET {1}
    REPEAT .LINES_TO_WAIT
        sta WSYNC
    REPEND
    ENDM
    
;--------
; SET_BLOCK_COLUMNS
; Original author: Andy Garber
; easy way to set my column counts
    MAC SET_BLOCK_COLUMNS
.COLUMN_COUNT SET {1}
    IF .COLUMN_COUNT = 6
        lda #%01110110
        sta NUSIZ0
        sta NUSIZ1
    ELSE
        IF .COLUMN_COUNT = 5
            lda #%01110110
            sta NUSIZ0
            lda #%01110010
            sta NUSIZ1
        ELSE
            IF .COLUMN_COUNT = 4
                lda #%01110010
                sta NUSIZ0
                sta NUSIZ1
            ELSE
                IF .COLUMN_COUNT = 3
                    lda #%01110010
                    sta NUSIZ0
                    lda #%01110001
                    sta NUSIZ1
                ELSE
                    IF .COLUMN_COUNT = 2
                        lda #%01110000
                        sta NUSIZ0
                        sta NUSIZ1
                    ELSE
                        ECHO "ERROR: SET_BLOCK_COLUMNS only supports 6-2"
                        ERR
                    ENDIF
                ENDIF
            ENDIF
        ENDIF
    ENDIF
    ENDM
;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;
;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;
;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;
; Variables segment

    seg.u Variables
    org $80

TempByte .byte


CONS_BQ_VERT_COLS        EQU #4
CONS_BQ_VERT_ROWS        EQU #5
CONS_BQ_VERT_ROW_HEIGHT  EQU #8
;
CONS_BQ_HORI_COLS        EQU #5
CONS_BQ_HORI_ROWS        EQU #3
CONS_BQ_HORI_ROW_HEIGHT  EQU #8
;
CONS_PLAYERZ_COLS        EQU #6
CONS_PLAYERZ_ROWS        EQU #3
CONS_PLAYERZ_ROW_HEIGHT  EQU #9
;
Player0Pos_Ptr .DS 2
Player0Pos_Col .byte
Player0Pos_Row .byte
Player0Pos_PF_Left1  .byte
Player0Pos_PF_Left2  .byte
Player0Pos_PF_Right0 .byte
Player0Pos_PF_Right1 .byte
Player0_Color  .byte
Player0_InputSettings .DS 2 ; 0 == current, 1 == previous
Player0Missle_X .byte
Player0Missle_Y .byte
;
CurrentScanline .byte
GameState .byte

BlockQueue_Data_Ptr .DS 2
BlockQueue_Addr_Ptr .DS 2

BlockQueue_Idx   .byte
	org $C0
BlockQueue_Top_0 .DS  #CONS_BQ_VERT_COLS
	org $C8
BlockQueue_Top_1 .DS  #CONS_BQ_VERT_COLS
	org $D0
BlockQueue_Top_2 .DS  #CONS_BQ_VERT_COLS
	org $D8
BlockQueue_Top_3 .DS  #CONS_BQ_VERT_COLS


LoopIdx .DS 2
;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;
;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;
;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;
; Code segment
    seg Code
    org $f000

Start
    CLEAN_START
;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;
; Lets build some mock data for the blocks

;;;;;;;;;;;;;;;;;;;;;;;
    lda #$00
    sta TempByte


    ldy #$00
Kernal_Temp_Rows
    FLIP_BOOL TempByte
    bne Kernal_Temp_B
Kernal_Temp_A
    lda #CONS_COLOR_ORANGE
    sta BlockQueue_Top_0,y
    lda #CONS_COLOR_RED
    sta BlockQueue_Top_1,y
    lda #CONS_COLOR_ORANGE
    sta BlockQueue_Top_2,y
    lda #CONS_COLOR_RED
    sta BlockQueue_Top_3,y    
    
    jmp Kernal_Temp_Next
Kernal_Temp_B
    lda #CONS_COLOR_RED
    sta BlockQueue_Top_0,y
    lda #CONS_COLOR_ORANGE
    sta BlockQueue_Top_1,y
    lda #CONS_COLOR_RED
    sta BlockQueue_Top_2,y
    lda #CONS_COLOR_ORANGE
    sta BlockQueue_Top_3,y    

Kernal_Temp_Next
    iny
    tya
    cmp #CONS_BQ_VERT_ROWS
    bcc Kernal_Temp_Rows

;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;
; Setup Other Player Things
    lda #$00
    sta Player0Pos_Col
    sta BlockQueue_Idx

    lda #$02
    sta Player0Pos_Row

    lda #CONS_COLOR_GREEN
    sta Player0_Color
;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;
;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;
;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;
; On Frame Code segment

NextFrame
    lsr SWCHB    ; test Game Reset switch
    bcc Start    ; reset?

; 1 + 3 lines of VSYNC
    VERTICAL_SYNC

;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;
; 37 lines of underscan

    TIMER_SETUP 37
    
;;;;;;;;;;;;;;;;;;;;;;;
; Set Positions
    sta WSYNC
    ;lda #20
    ;ldx #0           ; player 0
    ;jsr SetHorizPos
    
    jsr SetPositionMissles
;;;;;;;;;;;;;;;;;;;;;;;
; Set Player X -- todo make this a pointer and data table affair.
    ldy Player0Pos_Col
    LOAD_POINTER_WITH_DATA Player0Pos_Ptr,PlayerPositions_Columns
    lda (Player0Pos_Ptr),y
    ldx #0           ; player 0
    jsr SetHorizPos
    nop
    TIMER_WAIT

;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;
; 192 lines of frame

    TIMER_SETUP 192
;;;;;;;;;;;;;;;;;;;;;;;
    SET_BLOCK_COLUMNS CONS_BQ_VERT_COLS+1    
    lda #%00000001
    sta CTRLPF
    lda #CONS_COLOR_BLACK
    sta COLUPF
    
    lda #%00000000
    sta PF0
    lda #%00000000
    sta PF1
    lda #%00000000
    sta PF2
;;;;;;;;;;;;;;;;;;;;;;;
    ;TODO only kept here because we may put stuff above htis. think of it as just safegaurding for now
    lda #%00000000
    sta PF0
    lda #%00000000
    sta PF1
    lda #%00000000
    sta PF2
    
    lda #$00
    ldx #CONS_BQ_VERT_ROWS
    sta WSYNC
Kernal_TopBlocks
    ;TODO -- honsetly do I need this? Could just try to use the X value!
    ldy #CONS_BQ_VERT_ROW_HEIGHT
Kernal_TopBlocks.Rows
    sta WSYNC
    lda #%11111111
    sta ENAM0
    sta ENAM1
    
    SLEEP 7 ; 16 with web, 17 with stella
    
    lda BlockQueue_Top_0,x
    sta COLUP0

    lda BlockQueue_Top_1,x
    sta COLUP1
    
    lda BlockQueue_Top_2,x
    sta COLUP0
    
    lda BlockQueue_Top_3,x
    sta COLUP1

     SLEEP 7

    dey
    bne Kernal_TopBlocks.Rows
    
    lda #CONS_COLOR_BLACK
    sta COLUP0
    sta COLUP1
    
    dex
    bpl Kernal_TopBlocks
    lda #%00000000
    sta ENAM0
    sta ENAM1
;;;;;;;;;;;;;;;;;;;;;;;
    WYSNC_REPEATER 10
;;;;;;;;;;;;;;;;;;;;;;;
    
    lda #%00000000
    sta CTRLPF
   
    lda #CONS_COLOR_BLACK
    sta COLUPF
    
    lda #%00000000
    sta NUSIZ0
    sta NUSIZ1
    lda Player0_Color
    sta COLUP0
    
    lda #CONS_PLAYERZ_ROWS
    sta LoopIdx
    ldx #00
Kernal_PlayerZone
    ldy #CONS_PLAYERZ_ROW_HEIGHT
    
Kernal_PlayerZone.Rows
    sta WSYNC
    lda #CONS_COLOR_WHITE
    sta COLUBK
    
Kernal_PlayerZone.DrawPlayerfield.Left
    lda #%11110000
    sta PF0
    lda #%11111001
    sta PF1
    lda #%10011001
    sta PF2

Kernal_PlayerZone.PlayerLogic.ComparePlayer
    lda Player0Pos_Row
    cmp LoopIdx
    bne Kernal_PlayerZone.SkipPlayer 
Kernal_PlayerZone.DrawPlayer
    lda #$FF
    jmp Kernal_PlayerZone.DrawPlayerfield.Right
Kernal_PlayerZone.SkipPlayer 
    lda #$00
Kernal_PlayerZone.DrawPlayerfield.Right
    sta GRP0
    SLEEP 5
    lda #%10010000
    sta PF0
    lda #%10011111
    sta PF1
    lda #%11111111
    sta PF2
    

Kernal_PlayerZone.EndLine    
    lda #CONS_COLOR_BLACK
    sta COLUBK
    
    dey
    bne Kernal_PlayerZone.Rows
    sta WSYNC
    lda #$00
    sta GRP0
    
    inx
    sta WSYNC

    dec LoopIdx
    bne Kernal_PlayerZone

;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;
Kernal_StopVisuals
    lda #00
    sta GRP0
    sta GRP1
    sta ENAM0
    sta ENAM1
    
    lda #CONS_COLOR_BLACK
    sta COLUPF
    lda #%00000000
    sta PF0

    lda #%00000000
    sta PF1

    lda #%00000000
    sta PF2
;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;
Kernal_Inputs
    jsr ReadJoystick
    jsr setBlockQueueIdx ; TODO -- maybe move this into that 10 line gap we have after drawing top blocks?
;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;
Kernal_WaitTilEnd
    nop  ; at: 197 of 233 lines by this point, dont cross! note in PIA will be 232 if right.
    TIMER_WAIT
;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;
; 29 lines of overscan
Kernal_Overscan
    TIMER_SETUP 29
    nop
    TIMER_WAIT

; total = 262 lines, go to next frame
    jmp NextFrame

;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;
;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;
;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;
; Subroutines
SetPositionMissles 
    sta WSYNC
    lda #46 ;#46
    ldx #2           ; player 0 Missle
    jsr SetHorizPos

    sta WSYNC
    lda #62
    ldx #3           ; player 1 Missle
    jsr SetHorizPos
    rts
;;;;;;;;;;;;;;;;;;;;;;;    
; A = X coordinate
; X = player number (0 or 1)
SetHorizPos
        sta WSYNC	; start a new line
        sec		; set carry flag
SetHorizPos.1
	sbc #15		; subtract 15
	bcs SetHorizPos.1 ; branch until negative
	eor #7		; calculate fine offset
        asl
        asl
        asl
        asl
        sta RESP0,x	; fix coarse position
        sta HMP0,x	; set fine offset
        sta WSYNC
        sta HMOVE	; apply the previous fine position(s)
	sta HMCLR	; reset the old horizontal position(s)
        rts		; return to caller
;;;;;;;;;;;;;;;;;;;;;;;    
; 
; To redo -- this will be easier with 
handleFireButton
    LOAD_POINTER_WITH_DATA BlockQueue_Addr_Ptr,PlayerColMemAddresses
    ldy BlockQueue_Idx
    lda (BlockQueue_Addr_Ptr),y
    sta BlockQueue_Data_Ptr
    lda #>00
    sta BlockQueue_Data_Ptr+1

    ldy #00 
.handleFireButton.FindRowMem
   ; TODO -- this obviously becomes more complicated once we know what ROW we are looking at!
    lda (BlockQueue_Data_Ptr),y
    cmp #00           ; ----------    is empty
    beq .handleFireButton.gotoNextBlock
    cmp Player0_Color ; ----------    is the same color
    bne .handleFireButton.NoBlankNoMatch
.handleFireButton.NoBlankMatch
    ; here we will loop through the columns blacking out all of the 
    lda #CONS_COLOR_BLACK
    sta (BlockQueue_Data_Ptr),y
.handleFireButton.gotoNextBlock
    iny
    cmp #CONS_BQ_VERT_COLS
    bcc .handleFireButton.NoAction
.handleFireButton.NoBlankNoMatch
    sta TempByte
    lda Player0_Color
    sta (BlockQueue_Data_Ptr),y
    lda TempByte
    sta Player0_Color
.handleFireButton.NoAction
    rts
;;;;;;;;;;;;;;;;;;;;;;;    
; 
; 
setBlockQueueIdx
    ; we will set the BlockQueue_Idx to point to the proper index
    lda Player0Pos_Col ; maybe lessen this by ALWAYS adding this to our blockqueue?
    sta BlockQueue_Idx
    ; rows count from bottom UP apparently! starting at 1. my bad?
    lda Player0Pos_Row
    cmp #01
    bne .setBlockQueueIdx.noRowChange 
    ; add the col amount to our index since it'll be the next grouping!
    ; store that into BlockQueue_Idx
.setBlockQueueIdx.noRowChange 
    rts
;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;
;-----------------------------------------
; SWCHA -- directional register
; #%10000000 -- P1 Right
; #%01000000 -- P1 left
; #%00100000 -- P1 down
; #%00010000 -- P1 up
; #%00001000 -- P0 Right
; #%00000100 -- P0 left
; #%00000010 -- P0 down
; #%00000001 -- P0 up
ReadJoystick
      lda #%00000000
      sta Player0_InputSettings  ; Set current input state to 0
.ReadJoystick
; ----------------------
; LEFT
; ----------------------
      lda #%01000000
      bit SWCHA
      bne .checkRight

      lda Player0_InputSettings
      ora #%00000001
      sta Player0_InputSettings

; ----------------------
; RIGHT
; ----------------------
.checkRight
      lda #%10000000
      bit SWCHA
      bne .checkUp

      lda Player0_InputSettings
      ora #%00000010
      sta Player0_InputSettings

; ----------------------
; UP
; ----------------------
.checkUp
      lda #%00010000
      bit SWCHA
      bne .checkDown

      lda Player0_InputSettings
      ora #%00001000
      sta Player0_InputSettings

; ----------------------
; DOWN
; ----------------------
.checkDown
      lda #%00100000
      bit SWCHA
      bne .checkbutton

      lda Player0_InputSettings
      ora #%00010000
      sta Player0_InputSettings
      
.checkbutton
      bit INPT4
      bmi .determineJoystickAction ; released
      lda Player0_InputSettings
      ora #%00000100
      sta Player0_InputSettings
      
.determineJoystickAction
        lda Player0_InputSettings
        bne .storeCurrentInput
        lda Player0_InputSettings+1
        beq .storeCurrentInput

        tax
        ; Fire on release
        and #%00000100
        bne .fireOnRelease

; LEFT RELEASE
      txa
      and #%00000001
      bne .leftOnRelease

; RIGHT RELEASE
      txa
      and #%00000010
      bne .rightOnRelease

; UP RELEASE
      txa
      and #%00001000
      bne .upOnRelease

; DOWN RELEASE
      txa
      and #%00010000
      bne .downOnRelease
.leftOnRelease
    lda Player0Pos_Col
    cmp #$00
    beq .storeCurrentInput
    dec Player0Pos_Col
    jmp .storeCurrentInput
.rightOnRelease
    lda Player0Pos_Col
    cmp #CONS_PLAYERZ_COLS-2
    beq .storeCurrentInput
    inc Player0Pos_Col
    jmp .storeCurrentInput
.upOnRelease
    lda Player0Pos_Row
    cmp #CONS_PLAYERZ_ROWS
    beq .storeCurrentInput
    inc Player0Pos_Row
    jmp .storeCurrentInput
.downOnRelease
    lda Player0Pos_Row
    cmp #$01
    beq .storeCurrentInput
    dec Player0Pos_Row
    jmp .storeCurrentInput
.fireOnRelease
    jsr handleFireButton
.storeCurrentInput
    lda Player0_InputSettings
    sta Player0_InputSettings+1
.endJoystickCheck
      rts

;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;
;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;
;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;
; Data
;;;;;;;;;;;;;;;;;;;;;;;
PlayerColMemAddresses
    .byte BlockQueue_Top_0
    .byte BlockQueue_Top_1
    .byte BlockQueue_Top_2
    .byte BlockQueue_Top_3
    
;;;;;;;;;;;;;;;;;;;;;;;
PlayerPositions_Columns
    .byte #$2D
    .byte #$3D
    .byte #$4D
    .byte #$5D
    .byte #$6D
    .byte #$7D
;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;
;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;
;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;
; Epilogue

    org $fffc
    .word Start    ; reset vector
    .word Start    ; BRK vector