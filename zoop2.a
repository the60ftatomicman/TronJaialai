;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;
;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;
; Code segment
    seg Code
    org $f000

Start
    CLEAN_START
;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;
; Lets build some mock data for the blocks

;;;;;;;;;;;;;;;;;;;;;;;
    lda #$00
    sta TempByte


    ldy #$00
Kernal_Temp_Rows
    FLIP_BOOL TempByte
    bne Kernal_Temp_B
Kernal_Temp_A
    ;TOP
    lda #CONS_COLOR_ORANGE
    sta BlockQueue_Top_0,y
    lda #CONS_COLOR_ORANGE
    sta BlockQueue_Top_1,y
    lda #CONS_COLOR_ORANGE
    sta BlockQueue_Top_2,y
    lda #CONS_COLOR_RED
    sta BlockQueue_Top_3,y    
    lda #CONS_COLOR_ORANGE
    sta BlockQueue_Top_4,y
    ;BOT
    lda #CONS_COLOR_RED
    sta BlockQueue_Bot_0,y
    lda #CONS_COLOR_ORANGE
    sta BlockQueue_Bot_1,y
    lda #CONS_COLOR_RED
    sta BlockQueue_Bot_2,y
    lda #CONS_COLOR_ORANGE
    sta BlockQueue_Bot_3,y    
    lda #CONS_COLOR_RED
    sta BlockQueue_Bot_4,y
    
    jmp Kernal_Temp_Next
Kernal_Temp_B
    ;TOP
    lda #CONS_COLOR_RED
    sta BlockQueue_Top_0,y
    lda #CONS_COLOR_ORANGE
    sta BlockQueue_Top_1,y
    lda #CONS_COLOR_RED
    sta BlockQueue_Top_2,y
    lda #CONS_COLOR_ORANGE
    sta BlockQueue_Top_3,y    
    lda #CONS_COLOR_RED
    sta BlockQueue_Top_4,y
    ;BOT
    lda #CONS_COLOR_ORANGE
    sta BlockQueue_Bot_0,y
    lda #CONS_COLOR_ORANGE
    sta BlockQueue_Bot_1,y
    lda #CONS_COLOR_ORANGE
    sta BlockQueue_Bot_2,y
    lda #CONS_COLOR_RED
    sta BlockQueue_Bot_3,y    
    lda #CONS_COLOR_ORANGE
    sta BlockQueue_Bot_4,y
Kernal_Temp_Next
    iny
    tya
    cmp #CONS_BQ_VERT_ROWS
    bcc Kernal_Temp_Rows
    
;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;
; Setup Other Player Things
    lda #$02
    sta Player0Pos_Col
    sta BlockQueue_Idx

    lda #$02
    sta Player0Pos_Row
    lda #CONS_COLOR_GREEN
