;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;
Kernal_PreTime
    lda #%00000000
    sta PF0
    lda #%00000000
    sta PF1
    lda #%00000000
    sta PF2
    WYSNC_REPEATER 2
    lda #CONS_TIME_BG
    sta COLUBK
Kernal_PreTime.getNibbles    
    ; -- Always set the digit right nibble, we'll probably do this LATER in the code
    lda Time
    and #$0F
    sta Time
    lda Time+1
    and #$0F
    sta Time+1
    lda Time+2
    and #$0F
    sta Time+2
    ;-- loop over EVERY digit
    ldx #02
Kernal_PreTime.setNumAddresses
    ldy Time,x
    clc
    lda #$05 ; 0 ALWAYS starts at 5
Kernal_PreTime.loopaddress
    dey
    bmi Kernal_PreTime.addTempByte
    adc #$06
    jmp Kernal_PreTime.loopaddress
Kernal_PreTime.addTempByte  
    sta NumberIdx,x
    dex
    bpl Kernal_PreTime.setNumAddresses
    ;----------------
    ldy #$06
Kernal_Time
    WYSNC_REPEATER 1
    SLEEP 23 
    ldx NumberIdx+2
    lda Score_Numbers,x
    sta GRP1

    ldx NumberIdx+1
    lda Score_Numbers,x
    sta GRP1
    
    ldx NumberIdx
    lda Score_Numbers,x
    sta GRP1

    dec NumberIdx
    dec NumberIdx+1
    dec NumberIdx+2
    
    lda #$00
    sta GRP1
    WYSNC_REPEATER 1!
    
    dey
    bne Kernal_Time
Kernal_Time.lowerBuffer
    WYSNC_REPEATER 3
;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;
Kernal_StopVisuals
    lda #00
    sta GRP0
    sta GRP1
    sta ENAM0
    sta ENAM1
    
    lda #CONS_COLOR_BLACK
    sta COLUBK
    sta COLUPF
    
    lda #%00000000
    sta PF0
    lda #%00000000
    sta PF1
    lda #%00000000
    sta PF2
    
;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;
Kernal_Inputs
    jsr ReadJoystick
    jsr setBlockQueueIdx ; TODO -- maybe move this into that 10 line gap we have after drawing top blocks?
;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;
Kernal_DecrementTimer
    dec TimeDec
    bne Kernal_WaitTilEnd
    lda CONS_TIMER_FRAMES_PER_SEC
    sta TimeDec
Kernal_DecrementTimer.ActualDec
    sed
    dec Time
    bpl Kernal_WaitTilEnd
    lda #$09
    sta Time
    dec Time+1
    bpl Kernal_WaitTilEnd
    lda #$09
    sta Time+1
    dec Time+2
    bpl Kernal_WaitTilEnd
    lda #$09
    sta Time+2
;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;
Kernal_WaitTilEnd
    cld
    nop  ; at: 196 of 233 lines by this point, dont cross! note in PIA will be 232 if right.
    TIMER_WAIT
;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;
; 29 lines of overscan
Kernal_Overscan
    TIMER_SETUP 29
    dec NextColor
    bne Kernal_Overscan_Wait
    lda #$07
    sta NextColor
Kernal_Overscan_Wait
    nop
    TIMER_WAIT
; total = 262 lines, go to next frame
    jmp NextFrame

;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;
;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;
;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;
; Subroutines
SetPositionMissles 
    sta WSYNC
    lda #46 ;#46
    ldx #2           ; player 0 Missle
    jsr SetHorizPos

    sta WSYNC
    lda #62
    ldx #3           ; player 1 Missle
    jsr SetHorizPos
    rts
;;;;;;;;;;;;;;;;;;;;;;;    
; A = X coordinate
; X = player number (0 or 1)
SetHorizPos
        sta WSYNC	; start a new line
        sec		; set carry flag
SetHorizPos.1
	sbc #15		; subtract 15
	bcs SetHorizPos.1 ; branch until negative
	eor #7		; calculate fine offset
        asl
        asl
        asl
        asl
        sta RESP0,x	; fix coarse position
        sta HMP0,x	; set fine offset
        sta WSYNC
        sta HMOVE	; apply the previous fine position(s)
	sta HMCLR	; reset the old horizontal position(s)
        rts		; return to caller
;;;;;;;;;;;;;;;;;;;;;;;    
; 
handleFireButton
    ; -- we need to be able to go to the 
    lda Player0Pos_Row
    cmp #$02
    beq .handleFireButton.NoAction
    
    LOAD_POINTER_WITH_DATA BlockQueue_Addr_Ptr,PlayerColMemAddresses
    ldy BlockQueue_Idx
    lda (BlockQueue_Addr_Ptr),y
    sta BlockQueue_Data_Ptr
    lda #>00
    sta BlockQueue_Data_Ptr+1

    ldy #00 
.handleFireButton.FindRowMem
    tya
    cmp #CONS_BQ_VERT_ROW_HEIGHT+2 ; if we are at our limit, goto the END
    beq .handleFireButton.NoAction
    ; --- now look at blocks
    tay
    lda (BlockQueue_Data_Ptr),y
    cmp #CONS_COLOR_BLACK  ; ----------    is empty
    beq .handleFireButton.gotoNextBlock
    cmp  Player0_Color  ; ----------    is player color
    beq .handleFireButton.MatchingColor
    jmp .handleFireButton.swapWithBlock
.handleFireButton.MatchingColor
    ; here we will loop through the columns blacking out all of the
    lda #CONS_COLOR_BLACK
    sta (BlockQueue_Data_Ptr),y
    ; now do some score
    jsr .addScore
.handleFireButton.gotoNextBlock
    iny
    cmp #$00 ; is our accumulator 0?
    bcs .handleFireButton.FindRowMem
.handleFireButton.swapWithBlock
    lda (BlockQueue_Data_Ptr),y
    sta TempByte
    lda Player0_Color
    sta (BlockQueue_Data_Ptr),y
    lda TempByte
    sta Player0_Color
.handleFireButton.NoAction
    rts
;;;;;;;;;;;;;;;;;;;;;;;    
; 
; 
setBlockQueueIdx
    ; we will set the BlockQueue_Idx to point to the proper index
    ;lda Player0Pos_Col ; maybe lessen this by ALWAYS adding this to our blockqueue?
    ;sta BlockQueue_Idx
    ; rows count from bottom UP apparently! starting at 1. my bad?
    ldy #$00
    lda Player0Pos_Row
    cmp #01
    bne .setBlockQueueIdx.noRowChange
    REPEAT CONS_BQ_VERT_COLS
        iny
    REPEND 
.setBlockQueueIdx.noRowChange
    tya
    clc
    adc Player0Pos_Col
    sta BlockQueue_Idx
    rts
;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;
;-----------------------------------------
; SWCHA -- directional register
; #%10000000 -- P1 Right
; #%01000000 -- P1 left
; #%00100000 -- P1 down
; #%00010000 -- P1 up
; #%00001000 -- P0 Right
; #%00000100 -- P0 left
; #%00000010 -- P0 down
; #%00000001 -- P0 up
ReadJoystick
      lda #%00000000
      sta Player0_InputSettings  ; Set current input state to 0
.ReadJoystick
; ----------------------
; LEFT
; ----------------------
      lda #%01000000
      bit SWCHA
      bne .checkRight

      lda Player0_InputSettings
      ora #%00000001
      sta Player0_InputSettings

; ----------------------
; RIGHT
; ----------------------
.checkRight
      lda #%10000000
      bit SWCHA
      bne .checkUp

      lda Player0_InputSettings
      ora #%00000010
      sta Player0_InputSettings

; ----------------------
; UP
; ----------------------
.checkUp
      lda #%00010000
      bit SWCHA
      bne .checkDown

      lda Player0_InputSettings
      ora #%00001000
      sta Player0_InputSettings

; ----------------------
; DOWN
; ----------------------
.checkDown
      lda #%00100000
      bit SWCHA
      bne .checkbutton

      lda Player0_InputSettings
      ora #%00010000
      sta Player0_InputSettings
      
.checkbutton
      bit INPT4
      bmi .determineJoystickAction ; released
      lda Player0_InputSettings
      ora #%00000100
      sta Player0_InputSettings
      
.determineJoystickAction
        lda Player0_InputSettings
        bne .storeCurrentInput
        lda Player0_InputSettings+1
        beq .storeCurrentInput

        tax
        ; Fire on release
        and #%00000100
        bne .fireOnRelease

; LEFT RELEASE
      txa
      and #%00000001
      bne .leftOnRelease

; RIGHT RELEASE
      txa
      and #%00000010
      bne .rightOnRelease

; UP RELEASE
      txa
      and #%00001000
      bne .upOnRelease

; DOWN RELEASE
      txa
      and #%00010000
      bne .downOnRelease
.leftOnRelease
    lda Player0Pos_Col
    cmp #$00
    beq .storeCurrentInput
    dec Player0Pos_Col
    ;jsr .subtractScore ; TODO -- we want to implement NEGATIVE scores.
    jmp .storeCurrentInput
.rightOnRelease
    lda Player0Pos_Col
    cmp #CONS_PLAYERZ_COLS-2
    beq .storeCurrentInput
    inc Player0Pos_Col
    jmp .storeCurrentInput
.upOnRelease
    lda Player0Pos_Row
    cmp #CONS_PLAYERZ_ROWS
    beq .storeCurrentInput
    inc Player0Pos_Row
    jmp .storeCurrentInput
.downOnRelease
    lda Player0Pos_Row
    cmp #$01
    beq .storeCurrentInput
    dec Player0Pos_Row
    jmp .storeCurrentInput
.fireOnRelease
    jsr handleFireButton
.storeCurrentInput
    lda Player0_InputSettings
    sta Player0_InputSettings+1
.endJoystickCheck
      rts
;;;;;;;;;;;;;;;;;;;;;;;    
; 
; 
.addScore
    sta TempByte
    sed
    clc
    lda Score
    adc #01
    sta Score
    cmp #$10
    bne .addScore.end
    clc
    lda Score+1
    adc #$01
    sta Score+1
    cmp #$10
    bne .addScore.end
    clc
    lda Score+2
    adc #$01
    sta Score+2
    lda TempByte
.addScore.end    
    cld ; turn off decimal math
    rts
;;;;;;;;;;;;;;;;;;;;;;;    
; 
;     
.subtractScore
    sta TempByte
    sed
    sec
    lda Score
    sbc #01
    sta Score
    bpl .subtractScore.end
    sec
    lda Score+1
    sbc #$01
    sta Score+1
    bpl .subtractScore.end
    sec
    lda Score+2
    sbc #$01
    sta Score+2
    lda TempByte
.subtractScore.end
    cld ; turn off decimal math
    rts
