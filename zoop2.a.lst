     34  0000 ????						; Macros
     35  0000 ????						;--------
     36  0000 ????						; FLIP_BOOL
     37  0000 ????						; Original author: Andy Garber
     38  0000 ????						; Takes a memory address and flips it's value than stores it
     39  0000 ????						; Assumes the Memory address value is 1 or 0
     40  0000 ????						; usage: FLIP_BOOL SomeAddress
     41  0000 ????				      MAC	flip_bool
     42  0000 ????			   .MEMADDR   SET	{1}
     43  0000 ????				      lda	.MEMADDR
     44  0000 ????				      EOR	#$01
     45  0000 ????				      sta	.MEMADDR
     46  0000 ????				      ENDM
     47  0000 ????
     48  0000 ????						;--------
     49  0000 ????						; LOAD_POINTER_WITH_DATA
     50  0000 ????						; Original author: Andy Garber
     51  0000 ????						; Loads a pointer with low byte than high byte address of data object
     52  0000 ????						; usage: LOAD_POINTER_WITH_DATA pointer data
     53  0000 ????				      MAC	load_pointer_with_data
     54  0000 ????			   .POINTER   SET	{1}
     55  0000 ????			   .DATA_BLOB SET	{2}
     56  0000 ????				      lda	#<.DATA_BLOB
     57  0000 ????				      sta	.POINTER
     58  0000 ????				      lda	#>.DATA_BLOB
     59  0000 ????				      sta	.POINTER+1
     60  0000 ????				      ENDM
     61  0000 ????						;--------
     62  0000 ????						; WYSNC_REPEATER
     63  0000 ????						; Original author: Andy Garber
     64  0000 ????						; just a wrapper around REPEAT X lines of WSYNC. used to help with spacing in this game.
     65  0000 ????				      MAC	wysnc_repeater
     66  0000 ????			   .LINES_TO_WAIT SET	{1}
     67  0000 ????				      REPEAT	.LINES_TO_WAIT
     68  0000 ????				      sta	WSYNC
     69  0000 ????				      REPEND
     70  0000 ????				      ENDM
     71  0000 ????
     72  0000 ????						;--------
     73  0000 ????						; SET_BLOCK_COLUMNS
     74  0000 ????						; Original author: Andy Garber
     75  0000 ????						; easy way to set my column counts
     76  0000 ????				      MAC	set_block_columns
     77  0000 ????			   .COLUMN_COUNT SET	{1}
     78  0000 ????				      IF	.COLUMN_COUNT = 6
     79  0000 ????				      lda	#%01110110
     80  0000 ????				      sta	NUSIZ0
     81  0000 ????				      sta	NUSIZ1
     82  0000 ????				      ELSE
     83  0000 ????				      IF	.COLUMN_COUNT = 5
     84  0000 ????				      lda	#%01110110
     85  0000 ????				      sta	NUSIZ0
     86  0000 ????				      lda	#%01110010
     87  0000 ????				      sta	NUSIZ1
     88  0000 ????				      ELSE
     89  0000 ????				      IF	.COLUMN_COUNT = 4
     90  0000 ????				      lda	#%01110010
     91  0000 ????				      sta	NUSIZ0
     92  0000 ????				      sta	NUSIZ1
     93  0000 ????				      ELSE
     94  0000 ????				      IF	.COLUMN_COUNT = 3
     95  0000 ????				      lda	#%01110010
     96  0000 ????				      sta	NUSIZ0
     97  0000 ????				      lda	#%01110001
     98  0000 ????				      sta	NUSIZ1
     99  0000 ????				      ELSE
    100  0000 ????				      IF	.COLUMN_COUNT = 2
    101  0000 ????				      lda	#%01110000
    102  0000 ????				      sta	NUSIZ0
    103  0000 ????				      sta	NUSIZ1
    104  0000 ????				      ELSE
    105  0000 ????				      ECHO	"ERROR: SET_BLOCK_COLUMNS only supports 6-2"
    106  0000 ????				      ERR
    107  0000 ????				      ENDIF
    108  0000 ????				      ENDIF
    109  0000 ????				      ENDIF
    110  0000 ????				      ENDIF
    111  0000 ????				      ENDIF
    112  0000 ????				      ENDM
